---
import Layout from '../layouts/Layout.astro';

// We show the dev section if the build environment allows it
const showDevMode = import.meta.env.MODE === 'development' || true; 
---

<Layout title="Sign In | Stablecoin Escrow">
	<div class="max-w-md mx-auto mt-20">
		<div class="bg-white dark:bg-slate-900 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
			<div class="p-8 text-center bg-blue-600">
				<div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-full mb-4">
					<img src="/favicon.svg" alt="Logo" class="w-10 h-10 brightness-0 invert" />
				</div>
				<h2 class="text-2xl font-bold text-white">Identity Gateway</h2>
				<p class="text-blue-100 text-sm mt-2">Access the Stablecoin Escrow Platform</p>
			</div>

			<div class="p-8">
				<div id="discovery-view">
					<!-- High-Assurance: added novalidate to bypass browser pattern mismatch errors -->
					<form id="discovery-form" class="space-y-6" novalidate>
						<div>
							<label for="assumed-role" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Role to Assume</label>
							<select 
								id="assumed-role" 
								name="assumedRole"
								class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all"
							>
								<option value="Depositor">Joey (Depositor)</option>
								<option value="Beneficiary">Jimmy (Beneficiary)</option>
								<option value="EscrowMediator">Sally (Mediator)</option>
								<option value="CentralBank">Bob (Bank / Admin)</option>
							</select>
						</div>

						<div>
							<label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Corporate Email</label>
							<input 
								type="text" 
								id="email" 
								name="email" 
								required 
								placeholder="you@vdatacloud.com"
								class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all"
							/>
						</div>

						<button 
							type="submit" 
							id="submit-btn"
							class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-blue-500/30 transition-all transform active:scale-[0.98] flex items-center justify-center space-x-2"
						>
							<span>Continue to OIDC Sign In</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 01-1.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
							</svg>
						</button>

						<div class="relative flex py-4 items-center">
							<div class="flex-grow border-t border-slate-100 dark:border-slate-800"></div>
							<span class="flex-shrink mx-4 text-slate-300 dark:text-slate-600 text-[10px] font-black uppercase tracking-widest">or self-sovereign</span>
							<div class="flex-grow border-t border-slate-100 dark:border-slate-800"></div>
						</div>

						<button 
							type="button" 
							id="connect-wallet-btn"
							class="w-full border-2 border-blue-600/30 hover:border-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/20 text-blue-600 dark:text-blue-400 font-bold py-3 rounded-xl transition-all transform active:scale-[0.98] flex items-center justify-center space-x-2"
						>
							<span>Connect Canton Wallet</span>
						</button>
					</form>
				</div>

				<div id="wallet-select-view" class="hidden space-y-6">
					<div class="text-center">
						<h3 class="text-lg font-bold text-slate-800 dark:text-white">Canton Wallet Connected</h3>
						<p class="text-xs text-slate-400 mt-1">Select an account and role to continue</p>
					</div>

					<div class="space-y-4">
						<div>
							<label for="wallet-account-select" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Wallet Account (Decorated)</label>
							<select 
								id="wallet-account-select" 
								class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all"
							>
								<!-- Dynamically populated -->
							</select>
						</div>

						<div>
							<label for="wallet-role-select" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Role to Assume</label>
							<select 
								id="wallet-role-select" 
								class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all"
							>
								<option value="Depositor">Depositor</option>
								<option value="Beneficiary">Beneficiary</option>
								<option value="EscrowMediator">Mediator</option>
								<option value="CentralBank">Bank / Admin</option>
							</select>
						</div>

						<button 
							type="button" 
							id="confirm-wallet-login-btn"
							class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-blue-500/30 transition-all transform active:scale-[0.98] flex items-center justify-center space-x-2"
						>
							<span>Confirm & Sign Nonce</span>
						</button>
					</div>
				</div>

				<!-- JIT Provisioning Status Bar -->
				<div id="provisioning-status" class="hidden mt-6 space-y-4">
					<div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-1.5 overflow-hidden">
						<div id="status-bar" class="bg-blue-600 h-full transition-all duration-700 w-0"></div>
					</div>
					<p id="status-text" class="text-xs font-bold text-blue-600 dark:text-blue-400 text-center animate-pulse uppercase tracking-widest">
						Allocating Institutional Identity...
					</p>
				</div>

				{showDevMode && (
					<div class="mt-10">
						<div class="relative flex py-5 items-center">
							<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
							<span class="flex-shrink mx-4 text-slate-400 text-[10px] font-black uppercase tracking-widest">Development Bypass</span>
							<div class="flex-grow border-t border-slate-200 dark:border-slate-800"></div>
						</div>

						<div class="grid grid-cols-2 gap-3 mt-4" id="dev-roles">
							<button data-role="Depositor" class="p-3 border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-300 transition-all text-xs font-bold text-slate-600 dark:text-slate-400">Joey (Depositor)</button>
							<button data-role="Beneficiary" class="p-3 border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-300 transition-all text-xs font-bold text-slate-600 dark:text-slate-400">Jimmy (Beneficiary)</button>
							<button data-role="EscrowMediator" class="p-3 border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-300 transition-all text-xs font-bold text-slate-600 dark:text-slate-400">Sally (Mediator)</button>
							<button data-role="CentralBank" class="p-3 border border-slate-200 dark:border-slate-700 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-300 transition-all text-xs font-bold text-slate-600 dark:text-slate-400">Bob (Bank / Admin)</button>
						</div>

						<p class="mt-4 text-[10px] text-slate-400 text-center italic">
							Requires API running with ENVIRONMENT=dev and AUTH_BYPASS=true
						</p>
					</div>
				)}

				<div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-200 text-red-600 rounded-lg text-sm text-center">
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	import { handleLoginDiscovery, loginAsRole, setRedirect, getRedirect, finalizeWalletAuthentication } from '../lib/auth';
	import { fetchNonce, verifyWallet, fetchIdentities } from '../lib/api';

	const form = document.getElementById('discovery-form') as HTMLFormElement;
	const btn = document.getElementById('submit-btn') as HTMLButtonElement;
	const errorMsg = document.getElementById('error-msg');
	const devRoles = document.querySelectorAll('#dev-roles button');

	// Handle initial redirect capture
	const urlParams = new URLSearchParams(window.location.search);
	const returnTo = urlParams.get('returnTo');
	if (returnTo) {
		setRedirect(returnTo);
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const email = formData.get('email') as string;
		const assumedRole = formData.get('assumedRole') as string;
		
		if (!email) return;

		// Save the assumed role in localStorage before redirecting to OIDC
		localStorage.setItem('pending_assumed_role', assumedRole);

		btn.disabled = true;
		btn.innerText = 'Redirecting to Provider...';

		try {
			await handleLoginDiscovery(email);
		} catch (err: any) {
			console.error('Discovery failed', err);
			if (errorMsg) {
				errorMsg.innerText = 'Institutional discovery failed. Please check your email.';
				errorMsg.classList.remove('hidden');
			}
			btn.disabled = false;
			btn.innerText = 'Continue to OIDC Sign In';
		}
	});

	const discoveryView = document.getElementById('discovery-view');
	const walletSelectView = document.getElementById('wallet-select-view');
	const walletAccountSelect = document.getElementById('wallet-account-select') as HTMLSelectElement;
	const walletRoleSelect = document.getElementById('wallet-role-select') as HTMLSelectElement;
	const confirmWalletLoginBtn = document.getElementById('confirm-wallet-login-btn') as HTMLButtonElement;

	const provisioningStatus = document.getElementById('provisioning-status');
	const statusBar = document.getElementById('status-bar');
	const statusText = document.getElementById('status-text');

	const updateStatus = (pct: number, text: string) => {
		if (statusBar) statusBar.style.width = `${pct}%`;
		if (statusText) statusText.innerText = text;
	};

	// --- CIP-0103 Connected Wallet Login Flow ---
	const connectWalletBtn = document.getElementById('connect-wallet-btn') as HTMLButtonElement;

	function bufToHex(buffer: ArrayBuffer): string {
		return Array.prototype.map.call(new Uint8Array(buffer), x => ('00' + x.toString(16)).slice(-2)).join('');
	}

	let walletAccounts: string[] = [];

	connectWalletBtn?.addEventListener('click', async () => {
		btn.disabled = true;
		connectWalletBtn.disabled = true;
		connectWalletBtn.innerText = 'Connecting...';

		try {
			// Connect wallet (Emulator or Web3 provider)
			const canton = (window as any).canton;
			if (canton) {
				await canton.request({ method: 'canton_connect' });
				const accounts = await canton.request({ method: 'canton_accounts' });
				if (accounts && accounts.length > 0) {
					walletAccounts = accounts;
				} else {
					walletAccounts = ['Depositor::local-wallet', 'Beneficiary::local-wallet', 'EscrowMediator::local-wallet'];
				}
			} else {
				// MOCK DEVELOPER WALLET: Returns all dev participant identities
				walletAccounts = ['Depositor', 'Beneficiary', 'EscrowMediator', 'CentralBank'];
			}

			// Load and decorate identities
			const directory = await fetchIdentities();
			const decoratedOptions = walletAccounts.map(addr => {
				const match = directory.find((id: any) => id.damlUserId === addr || id.damlPartyId === addr);
				if (match) {
					return `<option value="${addr}">${match.displayName} (${match.role} - ${match.email})</option>`;
				}
				return `<option value="${addr}">${addr} (Undecorated Party ID)</option>`;
			}).join('');

			if (walletAccountSelect) {
				walletAccountSelect.innerHTML = decoratedOptions;
			}

			// Transition Views
			discoveryView?.classList.add('hidden');
			walletSelectView?.classList.remove('hidden');
		} catch (err: any) {
			alert('Wallet connection failed: ' + err.message);
			btn.disabled = false;
			connectWalletBtn.disabled = false;
			connectWalletBtn.innerText = 'Connect Canton Wallet';
		}
	});

	confirmWalletLoginBtn?.addEventListener('click', async () => {
		const selectedParty = walletAccountSelect.value;
		const assumedRole = walletRoleSelect.value;
		if (!selectedParty) return;

		// Show JIT status bar
		walletSelectView?.classList.add('hidden');
		provisioningStatus?.classList.remove('hidden');

		try {
			updateStatus(15, 'Retrieving secure challenge from bank...');
			const { nonce } = await fetchNonce();

			updateStatus(45, 'Signing platform authentication challenge...');
			let signatureHex = '';
			let publicHex = '';

			const canton = (window as any).canton;
			if (canton) {
				signatureHex = await canton.request({ method: 'canton_signMessage', params: [nonce] });
				publicHex = "00a1b2...";
			} else {
				// Browser emulation key pair signing
				const keyPair = await window.crypto.subtle.generateKey(
					{ name: "Ed25519" },
					true,
					["sign", "verify"]
				) as any;

				const sigBuffer = await window.crypto.subtle.sign(
					{ name: "Ed25519" },
					keyPair.privateKey,
					new TextEncoder().encode(nonce)
				);

				const exportedPub = await window.crypto.subtle.exportKey("raw", keyPair.publicKey);
				signatureHex = bufToHex(sigBuffer);
				publicHex = bufToHex(exportedPub);
			}

			updateStatus(75, 'Submitting cryptographic proof to platform verify...');
			const { token, identity } = await verifyWallet({
				nonce,
				signature: signatureHex,
				publicKey: publicHex,
				damlPartyId: selectedParty,
				assumedRole: assumedRole
			});

			updateStatus(90, 'Finalizing session context...');
			await finalizeWalletAuthentication(token, identity);

			setTimeout(() => {
				updateStatus(100, 'Identity Verified.');
				window.location.href = getRedirect();
			}, 800);

		} catch (err: any) {
			console.error('Wallet verification failed', err);
			alert('Wallet login failed: ' + err.message);
			walletSelectView?.classList.remove('hidden');
			provisioningStatus?.classList.add('hidden');
		}
	});

	devRoles.forEach(btn => {
		btn.addEventListener('click', async () => {
			const role = btn.getAttribute('data-role');
			if (!role) return;

			// Show High-Assurance Status Bar
			discoveryView?.classList.add('hidden');
			provisioningStatus?.classList.remove('hidden');
			if (errorMsg) errorMsg.classList.add('hidden');
			
			updateStatus(20, 'Authenticating institutional principal...');

			try {
				updateStatus(45, 'Allocating ledger identity...');
				await loginAsRole(role);
				updateStatus(85, 'Synchronizing tripartite roles...');
				
				setTimeout(() => {
					updateStatus(100, 'Handshake Verified.');
					window.location.href = getRedirect();
				}, 1000);

			} catch (err: any) {
				alert('Bypass failed: ' + err.message);
				discoveryView?.classList.remove('hidden');
				provisioningStatus?.classList.add('hidden');
			}
		});
	});
</script>
