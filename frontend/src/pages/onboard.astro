---
import Layout from '../layouts/Layout.astro';

const token = Astro.url.searchParams.get('token');
const userEmail = Astro.cookies.get('user_email')?.value;

// 1. Unauthenticated Guard
if (token && !userEmail) {
    return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}
---

<Layout title="Join Agreement | Stablecoin Escrow">
    <div class="max-w-2xl mx-auto py-12 px-4 sm:px-6 lg:py-16">
        <div id="onboard-content" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl shadow-xl overflow-hidden p-8 md:p-12 transition-all duration-500">
            
            {/* Error: Missing Token */}
            {!token && (
                <div class="text-center py-12">
                    <div class="w-16 h-16 bg-red-50 dark:bg-red-900/20 text-red-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 15c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <h2 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tight mb-2">Invalid Link</h2>
                    <p class="text-slate-500 dark:text-slate-400 italic">This onboarding link is missing a valid security token.</p>
                </div>
            )}

            {token && (
                <div id="invitation-details" class="opacity-0 translate-y-4 transition-all duration-700">
                    <div class="flex items-center space-x-2 mb-6">
                        <span class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)] animate-pulse"></span>
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Opaque Token Verified</span>
                    </div>

                    <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight mb-4">You've been added to an Escrow</h2>
                    
                    <div id="invite-info" class="space-y-6 mb-8">
                        <div class="p-6 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-slate-800">
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Target Role</p>
                                    <p id="role-display" class="text-lg font-bold text-slate-900 dark:text-white">...</p>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Assigned Identity</p>
                                    <p id="identity-display" class="text-lg font-bold text-blue-600">...</p>
                                </div>
                            </div>
                        </div>

                        <div class="border-t border-slate-100 dark:border-slate-800 pt-6">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Agreement Visibility: <span class="text-green-500">PRIVATE</span></p>
                            <div class="space-y-3">
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-slate-500">Amount:</span>
                                    <span id="amount-display" class="font-bold text-slate-900 dark:text-white">...</span>
                                </div>
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-slate-500">Condition Type:</span>
                                    <span id="terms-display" class="font-bold text-slate-900 dark:text-white">...</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="action-area" class="border-t border-slate-100 dark:border-slate-800 pt-8">
                        <div class="w-full text-center">
                            <div class="mb-6 p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800/50 flex items-center justify-between">
                                <div class="text-left">
                                    <p class="text-[10px] uppercase font-black text-slate-400">Authenticated As</p>
                                    <p class="text-xs font-bold text-blue-700 dark:text-blue-300">{userEmail}</p>
                                </div>
                                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                            </div>
                            <button 
                                id="claim-btn"
                                class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl text-xs font-black uppercase tracking-widest transition-all active:scale-95 shadow-xl shadow-blue-500/30 flex items-center justify-center space-x-3"
                            >
                                <span>Claim Identity & Access Contract</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
                            </button>
                        </div>
                    </div>
                </div>
            )}

            {/* Success State */}
            <div id="success-message" class="hidden text-center py-12 animate-in zoom-in-95 duration-500">
                <div class="w-20 h-20 bg-green-50 dark:bg-green-900/20 text-green-500 rounded-3xl flex items-center justify-center mx-auto mb-8">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tight mb-2">Access Granted</h2>
                <p class="text-slate-500 dark:text-slate-400 mb-8 italic">Cryptographic binding successful. Your ledger identity is now associated with this contract.</p>
                <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-1.5 max-w-xs mx-auto overflow-hidden">
                    <div class="bg-green-500 h-full w-full origin-left animate-progress"></div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    @keyframes progress {
        0% { transform: scaleX(0); }
        100% { transform: scaleX(1); }
    }
    .animate-progress {
        animation: progress 2s ease-out forwards;
    }
</style>

<script>
    import { fetchInvitationByToken, claimInvitation } from '../lib/api';

    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');

    if (token) {
        const detailsArea = document.getElementById('invitation-details');
        const roleEl = document.getElementById('role-display');
        const identityEl = document.getElementById('identity-display');
        const amountEl = document.getElementById('amount-display');
        const termsEl = document.getElementById('terms-display');

        // Fetch Invitation Details (Backend enforces identity suffix check)
        fetchInvitationByToken(token).then(invite => {
            if (roleEl) roleEl.textContent = invite.inviteeRole;
            if (identityEl) identityEl.textContent = invite.inviteeEmail;
            if (amountEl) amountEl.textContent = `${invite.asset.amount} ${invite.asset.currency}`;
            if (termsEl) termsEl.textContent = invite.terms.conditionType;

            // Reveal content
            detailsArea?.classList.remove('opacity-0', 'translate-y-4');
        }).catch(err => {
            console.error(err);
            if (detailsArea) {
                detailsArea.innerHTML = `
                    <div class="p-6 bg-red-50 border border-red-200 rounded-2xl text-center">
                        <p class="text-red-600 font-bold mb-2">Access Denied</p>
                        <p class="text-xs text-red-500">${err.message}</p>
                        <a href="/" class="mt-4 inline-block text-[10px] uppercase font-black text-slate-400 hover:text-slate-600">Return Home</a>
                    </div>
                `;
                detailsArea?.classList.remove('opacity-0', 'translate-y-4');
            }
        });
    }

    // Handle Claim Button
    const claimBtn = document.getElementById('claim-btn');
    claimBtn?.addEventListener('click', async () => {
        if (!token) return;
        
        try {
            claimBtn.disabled = true;
            claimBtn.innerHTML = `<span>Handshaking with Ledger...</span>`;
            
            await claimInvitation(token);
            
            // Show Success
            document.getElementById('invitation-details')?.classList.add('hidden');
            document.getElementById('success-message')?.classList.remove('hidden');
            
            setTimeout(() => {
                window.location.href = '/?tab=proposals';
            }, 2500);
        } catch (err) {
            alert("Cryptographic verification failed: " + err.message);
            window.location.reload();
        }
    });
</script>
