---
import Layout from '../layouts/Layout.astro';
import { fetchSettlements } from '../lib/api';

let settlements = [];
let error = null;

try {
	settlements = await fetchSettlements();
} catch (e) {
	error = e.message;
}
---

<Layout title="Pending Settlements | Stablecoin Escrow">
	<div class="mb-8">
		<h2 class="text-3xl font-extrabold text-gray-900">Pending Settlements</h2>
		<p class="text-gray-600 mt-1">Finalize payments released from escrow to transfer funds.</p>
	</div>

	{error && (
		<div class="bg-red-50 border-l-4 border-red-400 p-4 mb-8">
			<p class="text-sm text-red-700">Error loading settlements: {error}</p>
		</div>
	)}

	<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
		<table class="min-w-full divide-y divide-gray-200">
			<thead class="bg-gray-50">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Settlement ID / Status</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recipient</th>
					<th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
				</tr>
			</thead>
			<tbody class="bg-white divide-y divide-gray-200">
				{settlements.length === 0 ? (
					<tr>
						<td colspan="4" class="px-6 py-10 text-center text-gray-500 italic">No pending settlements.</td>
					</tr>
				) : (
					settlements.map(s => (
						<tr>
							<td class="px-6 py-4">
								<div class="text-sm font-mono text-indigo-600 bg-indigo-50 inline-block px-2 py-0.5 rounded mb-1">{s.id.substring(0, 16)}...</div>
								<div class="text-xs text-gray-500">{s.status}</div>
							</td>
							<td class="px-6 py-4">
								<div class="text-sm font-bold text-gray-900">{s.amount} {s.currency}</div>
							</td>
							<td class="px-6 py-4">
								<div class="text-sm text-gray-600">{s.recipient.split('::')[0]}</div>
								<div class="text-[10px] text-gray-400 font-mono">{s.recipient.split('::')[1]}</div>
							</td>
							<td class="px-6 py-4 text-right">
								<button 
									data-action="settle" 
									data-id={s.id}
									class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-indigo-700 transition-colors shadow-sm"
								>
									Finalize Payment
								</button>
							</td>
						</tr>
					))
				)}
			</tbody>
		</table>
	</div>
</Layout>

<script>
	import { settlePayment } from '../lib/api';

	const buttons = document.querySelectorAll('button[data-action="settle"]');
	buttons.forEach(btn => {
		btn.addEventListener('click', async (e) => {
			const target = e.currentTarget as HTMLButtonElement;
			const id = target.getAttribute('data-id');
			if (!id) return;

			target.disabled = true;
			target.textContent = 'Processing...';

			try {
				await settlePayment(id);
				window.location.reload();
			} catch (err) {
				alert('Settlement failed: ' + err.message);
				target.disabled = false;
				target.textContent = 'Finalize Payment';
			}
		});
	});
</script>
