---
import Layout from '../layouts/Layout.astro';

const adminCookie = Astro.cookies.get('admin-mode');
const isAdmin = adminCookie?.value === 'true';
---

<Layout title="Vault Registry | Stablecoin Escrow">
	<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
		<div>
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight text-left uppercase">Institutional Vaults</h2>
			<p class="text-slate-500 dark:text-slate-400 mt-1 font-medium text-left">Manage your authoritative stablecoin holdings and provider credentials.</p>
		</div>
		<div class="flex gap-3">
			<button id="configure-provider-btn" class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-xl text-xs font-bold shadow-sm hover:bg-slate-50 transition-all active:scale-95 cursor-pointer">
				Configure Provider
			</button>
			<button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-md shadow-blue-500/20 active:scale-95 transition-all">
				Register New Vault +
			</button>
		</div>
	</div>

	<div id="wallets-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
		<div class="col-span-full py-20 text-center text-slate-400 animate-pulse italic font-mono text-xs">
			Synchronizing with Institutional Provider...
		</div>
	</div>

	<!-- Provider Configuration Modal (New) -->
	<div id="config-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
		<div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
		<div class="relative bg-white dark:bg-slate-900 w-full max-w-lg rounded-3xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
			<div class="p-8">
				<h3 class="text-xl font-black text-slate-900 dark:text-white mb-2 uppercase tracking-tight text-left">Provider Configuration</h3>
				<p class="text-sm text-slate-500 mb-6 text-left">Select your authoritative stablecoin bridge.</p>
				
				<form id="config-form" class="space-y-6 text-left">
					<div>
						<label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Primary Provider</label>
						<select id="provider-select" name="provider" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
							<option value="mock">Simulation Mode (Mock)</option>
							<option value="bitgo">BitGo Enterprise (CaaS)</option>
							<option value="circle">Circle Programmable Wallets</option>
						</select>
					</div>

					<div id="bitgo-fields" class="hidden space-y-4 pt-4 border-t border-slate-100 dark:border-slate-800">
						<div>
							<label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">BitGo Express URL</label>
							<input type="text" name="expressUrl" placeholder="http://localhost:3080" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-xs font-mono dark:text-white" />
						</div>
						<div>
							<label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Access Token</label>
							<input type="password" name="accessToken" placeholder="v2.x.auth_token..." class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-xs font-mono dark:text-white" />
						</div>
					</div>

					<div class="flex justify-end gap-3 mt-8">
						<button type="button" id="close-config" class="px-6 py-2.5 text-xs font-bold text-slate-400 hover:text-slate-600 uppercase">Cancel</button>
						<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-2.5 rounded-xl text-xs font-bold shadow-lg shadow-blue-500/20 active:scale-95 transition-all">Save Changes</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<div class="mt-12 bg-slate-900 dark:bg-blue-600 rounded-3xl p-10 text-white shadow-xl relative overflow-hidden">
		<div class="relative z-10 max-w-2xl text-left">
			<h3 class="text-2xl font-black mb-4 tracking-tight uppercase">Authoritative CIP-0056 Bridge</h3>
			<p class="text-blue-100 leading-relaxed font-medium">
				The Vault Registry manages your connection to institutional stablecoin networks. 
				Upon escrow activation, your assets are cryptographically **Locked** via the CIP-0056 standard, 
				ensuring that settlement is driven solely by the ledger's verified state transitions.
			</p>
		</div>
		<div class="absolute right-0 bottom-0 opacity-10 translate-y-1/4 translate-x-1/4 scale-150">
			<svg class="w-96 h-96" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
		</div>
	</div>
</Layout>

<script>
	import { fetchWallets, fetchConfig, saveConfig } from '../lib/api';
	import { getSession } from '../lib/auth';

	const configModal = document.getElementById('config-modal');
	const configForm = document.getElementById('config-form') as HTMLFormElement;
	const providerSelect = document.getElementById('provider-select') as HTMLSelectElement;
	const bitgoFields = document.getElementById('bitgo-fields');

	async function loadConfig() {
		const session = getSession();
		if (!session) return;

		try {
			const provider = await fetchConfig(session.identity.damlUserId, 'stablecoin_provider');
			if (provider) {
				providerSelect.value = provider;
				toggleFields(provider);
			}
		} catch (err) {
			console.warn('No custom provider config found');
		}
	}

	function toggleFields(val: string) {
		if (val === 'bitgo') {
			bitgoFields?.classList.remove('hidden');
		} else {
			bitgoFields?.classList.add('hidden');
		}
	}

	providerSelect?.addEventListener('change', (e) => {
		toggleFields((e.target as HTMLSelectElement).value);
	});

	document.getElementById('configure-provider-btn')?.addEventListener('click', () => {
		configModal?.classList.remove('hidden');
		configModal?.classList.add('flex');
		loadConfig();
	});

	document.getElementById('close-config')?.addEventListener('click', () => {
		configModal?.classList.add('hidden');
		configModal?.classList.remove('flex');
	});

	configForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(configForm);
		const session = getSession();
		if (!session) return;

		try {
			await saveConfig(session.identity.damlUserId, 'stablecoin_provider', formData.get('provider'));
			if (formData.get('provider') === 'bitgo') {
				await saveConfig(session.identity.damlUserId, 'bitgo_express_url', formData.get('expressUrl'));
			}
			window.location.reload();
		} catch (err: any) {
			alert('Failed to save config: ' + err.message);
		}
	});

	async function init() {
		const grid = document.getElementById('wallets-grid');
		if (!grid) return;

		try {
			const wallets = await fetchWallets();
			
			let html = wallets.map(w => `
				<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden flex flex-col transition-all hover:shadow-md text-left">
					<div class="p-6 flex-grow text-left">
						<div class="flex justify-between items-start mb-4">
							<div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/20 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
							</div>
							<span class="text-[10px] font-black text-slate-400 uppercase tracking-widest bg-slate-50 dark:bg-slate-800 px-2 py-1 rounded">CIP-0056 Vault</span>
						</div>
						<h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1 text-left">Vault ID (Contract Reference)</h3>
						<code class="text-xs text-blue-600 dark:text-blue-400 font-mono bg-blue-50 dark:bg-blue-900/20 px-2 py-1 rounded block truncate text-left">${w.id}</code>
						
						<div class="mt-6 text-left">
							<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Confirmed Holdings</p>
							<p class="text-3xl font-black text-slate-900 dark:text-white mt-1">
								${w.balance.toLocaleString(undefined, { minimumFractionDigits: 2 })}
								<span class="text-sm font-medium text-slate-400 italic ml-1">${w.currency}</span>
							</p>
						</div>
					</div>
					<div class="bg-slate-50 dark:bg-slate-800/50 p-4 border-t border-slate-100 dark:border-slate-800 grid grid-cols-2 gap-3">
						<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 transition-all active:scale-95 shadow-sm cursor-pointer">
							Lock
						</button>
						<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-50 dark:hover:bg-indigo-900/20 hover:text-indigo-600 transition-all active:scale-95 shadow-sm cursor-pointer">
							Sweep
						</button>
					</div>
				</div>
			`).join('');

			// Add the static "Add Provider" button
			html += `
				<div class="border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-2xl flex flex-col items-center justify-center p-8 text-center bg-slate-50/30 dark:bg-slate-900/30 transition-colors hover:border-blue-500/30 group">
					<div class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 mb-4 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/20 group-hover:text-blue-500 transition-all">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
					</div>
					<h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-tight">Add Vault</h3>
					<p class="text-xs text-slate-500 dark:text-slate-400 mt-1 italic">Connect an institutional vault provider.</p>
				</div>
			`;

			grid.innerHTML = html;

		} catch (err) {
			grid.innerHTML = `<div class="col-span-full text-center text-red-500 font-mono text-xs py-10">Error: ${err.message}</div>`;
		}
	}

	init();
</script>
