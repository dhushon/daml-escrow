---
import Layout from '../layouts/Layout.astro';
import { fetchWallets } from '../lib/api';

const adminCookie = Astro.cookies.get('admin-mode');
const isAdmin = adminCookie?.value === 'true';
const user = isAdmin ? 'CentralBank' : 'Buyer';

let wallets = [];
let error = null;

try {
	wallets = await fetchWallets(user);
} catch (e) {
	error = e.message;
}
---

<Layout title="Wallet Registry | Stablecoin Escrow">
	<div class="mb-8 flex justify-between items-end">
		<div>
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Stablecoin Wallets</h2>
			<p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">Manage your external digital asset accounts and ledger bridges.</p>
		</div>
		<button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-md shadow-blue-500/20 active:scale-95 transition-all">
			Register New Wallet +
		</button>
	</div>

	{error && (
		<div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 mb-8 rounded-r-xl font-mono transition-colors">
			<p class="text-sm font-bold text-red-700 dark:text-red-400">Error: {error}</p>
		</div>
	)}

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
		{wallets.map(w => (
			<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden flex flex-col transition-all hover:shadow-md">
				<div class="p-6 flex-grow">
					<div class="flex justify-between items-start mb-4">
						<div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/20 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
						</div>
						<span class="text-[10px] font-black text-slate-400 uppercase tracking-widest bg-slate-50 dark:bg-slate-800 px-2 py-1 rounded">Mock Account</span>
					</div>
					<h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Account ID</h3>
					<code class="text-xs text-blue-600 dark:text-blue-400 font-mono bg-blue-50 dark:bg-blue-900/20 px-2 py-1 rounded block truncate">{w.id}</code>
					
					<div class="mt-6">
						<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Available Balance</p>
						<p class="text-3xl font-black text-slate-900 dark:text-white mt-1">
							{w.balance.toLocaleString(undefined, { minimumFractionDigits: 2 })}
							<span class="text-sm font-medium text-slate-400 italic ml-1">{w.currency}</span>
						</p>
					</div>
				</div>
				<div class="bg-slate-50 dark:bg-slate-800/50 p-4 border-t border-slate-100 dark:border-slate-800 grid grid-cols-2 gap-3">
					<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 transition-all active:scale-95 shadow-sm">
						Transfer to Escrow
					</button>
					<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-50 dark:hover:bg-indigo-900/20 hover:text-indigo-600 transition-all active:scale-95 shadow-sm">
						Withdraw
					</button>
				</div>
			</div>
		))}

		<div class="border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-2xl flex flex-col items-center justify-center p-8 text-center bg-slate-50/30 dark:bg-slate-900/30 transition-colors hover:border-blue-500/30 group">
			<div class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 mb-4 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/20 group-hover:text-blue-500 transition-all">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
			</div>
			<h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-tight">Add Provider</h3>
			<p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Connect a new stablecoin wallet provider via API.</p>
		</div>
	</div>

	<div class="mt-12 bg-blue-600 rounded-3xl p-10 text-white shadow-xl relative overflow-hidden">
		<div class="relative z-10 max-w-2xl">
			<h3 class="text-2xl font-black mb-4 tracking-tight uppercase">Simulated Bridge</h3>
			<p class="text-blue-100 leading-relaxed font-medium">
				The Wallet Registry simulates the connection between your external digital asset holdings and the on-ledger escrow system. 
				In a production environment, "Transfer to Escrow" would trigger a cross-chain swap or a multi-sig lock on the target stablecoin network.
			</p>
		</div>
		<div class="absolute right-0 bottom-0 opacity-10 translate-y-1/4 translate-x-1/4 scale-150">
			<svg class="w-96 h-96" fill="currentColor" viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
		</div>
	</div>
</Layout>
