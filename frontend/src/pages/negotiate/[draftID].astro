---
import Layout from '../../layouts/Layout.astro';
import { fetchDraft, amendDraft, approveDraft, promoteDraftToLedger } from '../../lib/api';

const { draftID } = Astro.params;
---

<Layout title="Negotiate Agreement">
	<main class="max-w-4xl mx-auto px-6 py-12">
		<header class="mb-12">
			<h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight uppercase">Negotiate Agreement</h1>
			<p class="text-slate-500 dark:text-slate-400 mt-2 font-medium">Review, amend, and ratify the off-chain draft before ledger promotion.</p>
		</header>

		<div id="draft-loading" class="py-12 text-center">
			<div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
			<p class="mt-4 text-slate-500 font-bold">Fetching latest version...</p>
		</div>

		<div id="draft-container" class="hidden animate-fade-in">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				<!-- Left Column: Agreement Terms & Details -->
				<div class="lg:col-span-2 space-y-8">
					<div class="glass-card rounded-3xl p-8">
						<div class="flex justify-between items-start mb-6">
							<div>
								<h2 id="draft-title" class="text-xl font-black text-slate-900 dark:text-white tracking-tight uppercase">Escrow Agreement Draft</h2>
								<p id="draft-meta" class="text-xs text-brand-500 font-mono mt-1 font-bold"></p>
							</div>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
							<div class="space-y-2">
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Depositor (Funds Source)</label>
								<div class="bg-slate-50/50 dark:bg-slate-950/50 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
									<div id="display-depositor" class="text-xs font-mono text-slate-700 dark:text-slate-300 truncate font-bold">Fetching...</div>
								</div>
							</div>
							<div class="space-y-2">
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Beneficiary (Funds Target)</label>
								<div class="bg-slate-50/50 dark:bg-slate-950/50 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
									<div id="display-beneficiary" class="text-xs font-mono text-slate-700 dark:text-slate-300 truncate font-bold">Fetching...</div>
								</div>
							</div>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Financials (Pledge Amount)</label>
								<div class="bg-slate-50/50 dark:bg-slate-950/50 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
									<div class="text-2xl font-black text-slate-900 dark:text-white leading-none tracking-tight">
										<span id="display-amount">0.00</span> <span id="display-currency" class="text-xs font-black text-brand-500">USD</span>
									</div>
								</div>
							</div>
							<div class="space-y-2">
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Version History</label>
								<div class="bg-slate-50/50 dark:bg-slate-950/50 p-4 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
									<p id="display-version" class="text-xs font-black text-slate-900 dark:text-white">Version 1</p>
									<p id="display-summary" class="text-[10px] text-slate-400 dark:text-slate-500 mt-1 italic leading-relaxed">Initial Proposal</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Status & Timeline Cockpit -->
				<div class="space-y-8">
					<div class="glass-card rounded-3xl p-8 flex flex-col justify-between h-full min-h-[400px]">
						<div>
							<div class="flex justify-between items-center mb-6">
								<span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Timeline Status</span>
								<span id="draft-status" class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all"></span>
							</div>

							<div class="space-y-4 mb-8">
								<p id="initiator-info" class="text-[9px] font-black text-brand-500 uppercase tracking-wider bg-brand-500/10 px-3 py-2 rounded-xl border border-brand-500/10 inline-block"></p>
							</div>

							<div class="space-y-3">
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Bilateral Signatures</label>
								<div id="approvals-list" class="space-y-2">
									<!-- Approvals inject here -->
								</div>
							</div>
						</div>

						<!-- Actions footer inside right card -->
						<div class="flex flex-col gap-3 pt-6 border-t border-slate-100 dark:border-slate-800/60 mt-8">
							<button id="btn-approve" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-wider hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-emerald-500/20 cursor-pointer border-none">
								Approve Version
							</button>
							<button id="btn-amend" class="w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-wider hover:scale-[1.02] active:scale-95 transition-all shadow-lg cursor-pointer border-none">
								Propose Amendment
							</button>
							<button id="btn-promote" class="hidden w-full bg-brand-600 hover:bg-brand-700 text-white py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-wider hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-brand-500/20 cursor-pointer border-none">
								Promote to Ledger
							</button>
						</div>
					</div>
				</div>
			</div>

			<!-- Amendment Modal -->
			<div id="amend-modal" class="hidden fixed inset-0 bg-slate-950/60 backdrop-blur-md z-50 flex items-center justify-center p-6 animate-fade-in">
				<div class="glass-card w-full max-w-lg rounded-3xl p-8 shadow-2xl">
					<h3 class="text-xl font-black text-slate-900 dark:text-white mb-6 uppercase tracking-tight">Propose Amendment</h3>
					<div class="space-y-6">
						<div>
							<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 mb-2 uppercase tracking-widest">Change Summary</label>
							<textarea id="amend-summary" class="w-full bg-slate-50/50 dark:bg-slate-950/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl p-4 text-xs focus:ring-2 focus:ring-brand-500 focus:outline-none dark:text-white h-24 font-medium" placeholder="Describe the amendment details..."></textarea>
						</div>
						<div class="grid grid-cols-2 gap-4">
							<div>
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 mb-2 uppercase tracking-widest">New Amount</label>
								<input type="number" id="amend-amount" class="w-full bg-slate-50/50 dark:bg-slate-950/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl p-4 text-xs focus:ring-2 focus:ring-brand-500 focus:outline-none dark:text-white font-bold" />
							</div>
							<div>
								<label class="block text-[9px] font-black text-slate-400 dark:text-slate-500 mb-2 uppercase tracking-widest">Currency</label>
								<input type="text" id="amend-currency" class="w-full bg-slate-50/50 dark:bg-slate-950/50 border border-slate-200/50 dark:border-slate-800/50 rounded-2xl p-4 text-xs focus:ring-2 focus:ring-brand-500 focus:outline-none text-slate-400 font-bold" readonly />
							</div>
						</div>
						<div class="flex gap-4 pt-4 border-t border-slate-100 dark:border-slate-800/60">
							<button id="btn-submit-amend" class="flex-1 bg-brand-600 text-white py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-wider hover:bg-brand-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-brand-500/20 cursor-pointer border-none">Submit Proposal</button>
							<button id="btn-close-amend" class="flex-1 bg-slate-100 dark:bg-slate-800/60 text-slate-700 dark:text-slate-300 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-wider hover:scale-[1.02] active:scale-95 transition-all cursor-pointer border-none">Cancel</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	import { fetchDraft, amendDraft, approveDraft, promoteDraftToLedger } from '../../lib/api';

	const pathParts = window.location.pathname.split('/');
	const draftID = pathParts[pathParts.length - 1];

	let currentDraft = null;

	async function init() {
		try {
			currentDraft = await fetchDraft(draftID);
			render();
		} catch (err) {
			console.error(err);
			alert('Failed to load draft.');
		}
	}

	function render() {
		document.getElementById('draft-loading').classList.add('hidden');
		document.getElementById('draft-container').classList.remove('hidden');

		document.getElementById('draft-meta').innerText = `Root ID: ${currentDraft.rootId}`;
		document.getElementById('display-depositor').innerText = currentDraft.depositorId || 'Pending...';
		document.getElementById('display-beneficiary').innerText = currentDraft.beneficiaryEmail;
		document.getElementById('initiator-info').innerText = `Initiated by ${currentDraft.initiatorRole}: ${currentDraft.initiatorId}`;
		document.getElementById('display-amount').innerText = currentDraft.amount.toLocaleString();
		document.getElementById('display-currency').innerText = currentDraft.currency;
		document.getElementById('display-version').innerText = `Version ${currentDraft.version}`;
		document.getElementById('display-summary').innerText = currentDraft.changeSummary || 'Initial Proposal';

		const statusEl = document.getElementById('draft-status');
		statusEl.innerText = currentDraft.status;
		
		const statusColors = {
			DRAFT: 'text-slate-500 bg-slate-500/10 border-slate-500/20',
			NEGOTIATION: 'text-brand-500 bg-brand-500/10 border-brand-500/20',
			RATIFIED: 'text-emerald-500 bg-emerald-500/10 border-emerald-500/20',
			PROMOTED: 'text-purple-500 bg-purple-500/10 border-purple-500/20'
		};
		statusEl.className = `px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all ${statusColors[currentDraft.status] || 'text-slate-500 bg-slate-500/10 border-slate-500/20'}`;

		// Approvals
		const approvalsList = document.getElementById('approvals-list');
		approvalsList.innerHTML = '';
		if (currentDraft.approvals && currentDraft.approvals.length > 0) {
			currentDraft.approvals.forEach(user => {
				const badge = document.createElement('div');
				badge.className = 'flex items-center space-x-2 bg-emerald-500/10 text-emerald-500 text-[9px] font-black uppercase tracking-wider px-3.5 py-2 rounded-xl border border-emerald-500/10';
				badge.innerHTML = `<svg class="w-3 h-3 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg><span class="truncate">${user.split('::')[0]} Authorized</span>`;
				approvalsList.appendChild(badge);
			});
		} else {
			approvalsList.innerHTML = '<div class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest bg-slate-50/50 dark:bg-slate-950/50 px-3.5 py-2.5 rounded-xl border border-slate-200/50 dark:border-slate-800/50">Bilateral authorization pending...</div>';
		}

		// Promotion Logic
		if (currentDraft.status === 'RATIFIED') {
			document.getElementById('btn-promote').classList.remove('hidden');
		} else {
			document.getElementById('btn-promote').classList.add('hidden');
		}
	}

	// Interaction
	document.getElementById('btn-approve').onclick = async () => {
		try {
			await approveDraft(draftID);
			window.location.reload();
		} catch (err) {
			alert(err.message);
		}
	};

	document.getElementById('btn-amend').onclick = () => {
		document.getElementById('amend-amount').value = currentDraft.amount;
		document.getElementById('amend-currency').value = currentDraft.currency;
		document.getElementById('amend-modal').classList.remove('hidden');
	};

	document.getElementById('btn-close-amend').onclick = () => {
		document.getElementById('amend-modal').classList.add('hidden');
	};

	document.getElementById('btn-submit-amend').onclick = async () => {
		const req = {
			summary: document.getElementById('amend-summary').value,
			amount: parseFloat(document.getElementById('amend-amount').value),
			currency: document.getElementById('amend-currency').value,
			terms: currentDraft.terms,
			metadata: currentDraft.metadata
		};
		try {
			await amendDraft(draftID, req);
			window.location.reload();
		} catch (err) {
			alert(err.message);
		}
	};

	document.getElementById('btn-promote').onclick = async () => {
		try {
			const res = await promoteDraftToLedger(draftID);
			alert('Agreement promoted to ledger!');
			window.location.href = '/';
		} catch (err) {
			alert(err.message);
		}
	};

	init();
</script>
