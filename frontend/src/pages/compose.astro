---
import Layout from '../layouts/Layout.astro';
import InviteModal from '../components/InviteModal.astro';

const schemas = [
	{ id: 'grants', name: 'Research Grant', url: 'https://stablecoin-escrow.io/schemas/grants.v1.json' },
	{ id: 'leasing', name: 'Equipment Leasing', url: 'https://stablecoin-escrow.io/schemas/leasing.v1.json' },
	{ id: 'supply-chain', name: 'Supply Chain', url: 'https://stablecoin-escrow.io/schemas/supply-chain.v1.json' },
];

const defaultPayload = JSON.stringify({ description: "Standard escrow protocol" }, null, 2);
---

<Layout title="Compose Agreement | Stablecoin Escrow">
	<div class="max-w-4xl mx-auto text-left">
		<div class="mb-8 text-left">
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight uppercase">Draft Escrow Agreement</h2>
			<p class="text-slate-500 dark:text-slate-400 mt-1 font-medium text-left">Propose new terms and milestones to your counterparty.</p>
		</div>

		<form id="compose-form" class="space-y-8 text-left">
			<div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors text-slate-900">
				<div class="flex justify-between items-center mb-6">
					<h3 class="text-xs font-black text-blue-600 dark:text-blue-400 uppercase tracking-widest">1. Agreement Parties</h3>
					<button type="button" id="open-invite-btn" class="text-[10px] font-bold text-blue-600 dark:text-blue-400 hover:underline cursor-pointer bg-transparent border-none">Invite New Counterparty +</button>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end mb-6">
					<div class="md:col-span-5 text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Select Identity</label>
						<select id="counterparty-select" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
							<option value="">Searching institutional directory...</option>
						</select>
					</div>
					<div class="md:col-span-4 text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Assign Role</label>
						<select id="role-select" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
							<option value="Depositor">Depositor (Pledger)</option>
							<option value="Beneficiary">Beneficiary (Payee)</option>
						</select>
					</div>
					<div class="md:col-span-3">
						<button type="button" id="add-party-btn" class="w-full bg-slate-900 hover:bg-slate-800 dark:bg-blue-600 dark:hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-xl text-sm border-none cursor-pointer active:scale-95 transition-all">Add Counterparty</button>
					</div>
				</div>

				<!-- Stakeholder Roster List -->
				<div class="mb-6">
					<label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Roster of Escrow Stakeholders</label>
					<div id="roster-container" class="space-y-2">
						<!-- Roster rows injected by JS -->
						<div id="empty-roster-msg" class="text-xs text-slate-400 italic py-4 text-center border border-dashed border-slate-200 dark:border-slate-800 rounded-xl">
							No counterparties added yet. (Your self-identity will be automatically included as a depositor).
						</div>
					</div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-4 border-t border-slate-100 dark:border-slate-800/40">
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Depositor Threshold</label>
						<input type="number" id="depositor-threshold-input" name="depositorThreshold" min="1" value="1" required class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white" />
						<p class="mt-1 text-[9px] text-slate-400">Min signatures required from depositors.</p>
					</div>
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Beneficiary Threshold</label>
						<input type="number" id="beneficiary-threshold-input" name="beneficiaryThreshold" min="1" value="1" required class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white" />
						<p class="mt-1 text-[9px] text-slate-400">Min signatures required from beneficiaries.</p>
					</div>
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Currency</label>
						<select name="currency" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
							<option value="USD">USD - Digital Dollar</option>
							<option value="EUR">EUR - Digital Euro</option>
							<option value="GBP">GBP - Digital Sterling</option>
						</select>
					</div>
				</div>
			</div>

			<div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors text-slate-900">
				<h3 class="text-xs font-black text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-6">2. Select Mediator</h3>
				<div class="text-left">
					<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Authorized Mediator</label>
					<select id="mediator-select" name="mediator" required class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
						<option value="">Searching mediators...</option>
					</select>
				</div>
			</div>

			<div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors text-slate-900">
				<div class="flex justify-between items-center mb-6">
					<h3 class="text-xs font-black text-blue-600 dark:text-blue-400 uppercase tracking-widest">3. Payment Milestones</h3>
					<button type="button" id="add-milestone" class="text-[10px] font-bold text-blue-600 dark:text-blue-400 hover:underline cursor-pointer bg-transparent border-none">Add Row +</button>
				</div>
				<div id="milestone-container" class="space-y-4 text-left">
					<div class="milestone-row grid grid-cols-12 gap-4 items-end">
						<div class="col-span-7 text-left">
							<label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Label</label>
							<input type="text" name="m-label" required placeholder="e.g. Project Inception" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-3 py-2 text-xs dark:text-white" />
						</div>
						<div class="col-span-4 text-left">
							<label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Amount</label>
							<input type="number" name="m-amount" required step="0.01" placeholder="0.00" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-3 py-2 text-xs dark:text-white" />
						</div>
						<div class="col-span-1 py-2 text-center">
							<button type="button" class="remove-milestone text-slate-300 hover:text-red-500 cursor-pointer bg-transparent border-none">x</button>
						</div>
					</div>
				</div>
			</div>

			<div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors text-slate-900">
				<h3 class="text-xs font-black text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-6 text-left">4. Technical Metadata</h3>
				<div class="space-y-6">
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Schema Protocol</label>
						<select name="schemaUrl" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">
							{schemas.map((s) => (
								<option value={s.url}>{s.name}</option>
							))}
						</select>
					</div>
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Metadata Payload (JSON)</label>
						<textarea name="payload" rows="4" placeholder="Enter JSON Metadata" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-xs font-mono focus:ring-2 focus:ring-blue-500 outline-none transition-all dark:text-white">{defaultPayload}</textarea>
					</div>
				</div>
			</div>

			<div class="flex items-center justify-end space-x-4 pb-12">
				<a href="/" class="text-xs font-bold text-slate-400 hover:text-slate-600 transition-colors uppercase tracking-widest">Cancel</a>
				<button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-2xl text-sm font-bold shadow-xl shadow-blue-500/20 active:scale-95 transition-all border-none cursor-pointer">
					Save & Share Draft
				</button>
			</div>
		</form>
	</div>

	<InviteModal />
</Layout>

<script>
	import { saveDraft, fetchIdentities } from '../lib/api';
	import { getSession } from '../lib/auth';

	const form = document.getElementById('compose-form') as HTMLFormElement;
	const addBtn = document.getElementById('add-milestone');
	const container = document.getElementById('milestone-container');
	const counterpartySelect = document.getElementById('counterparty-select') as HTMLSelectElement;
	const mediatorSelect = document.getElementById('mediator-select') as HTMLSelectElement;
	const openInviteBtn = document.getElementById('open-invite-btn');

	let roster: Array<{ email: string; role: 'Depositor' | 'Beneficiary'; label: string }> = [];

	const rosterContainer = document.getElementById('roster-container');
	const addPartyBtn = document.getElementById('add-party-btn');
	const roleSelect = document.getElementById('role-select') as HTMLSelectElement;
	const depThresholdInput = document.getElementById('depositor-threshold-input') as HTMLInputElement;
	const benThresholdInput = document.getElementById('beneficiary-threshold-input') as HTMLInputElement;

	addPartyBtn?.addEventListener('click', () => {
		const email = counterpartySelect.value;
		const role = roleSelect.value as 'Depositor' | 'Beneficiary';
		const selectedText = counterpartySelect.options[counterpartySelect.selectedIndex]?.text || email;

		if (!email) {
			alert('Please select a counterparty');
			return;
		}

		if (roster.some(item => item.email === email)) {
			alert('This counterparty is already in the roster');
			return;
		}

		roster.push({ email, role, label: selectedText });
		renderRoster();
		updateThresholdBounds();
	});

	function renderRoster() {
		if (!rosterContainer) return;

		// Clear old roster
		rosterContainer.innerHTML = '';

		if (roster.length === 0) {
			rosterContainer.innerHTML = `
				<div id="empty-roster-msg" class="text-xs text-slate-400 italic py-4 text-center border border-dashed border-slate-200 dark:border-slate-800 rounded-xl">
					No counterparties added yet. (Your self-identity will be automatically included as a depositor).
				</div>
			`;
			return;
		}

		roster.forEach((item, index) => {
			const row = document.createElement('div');
			row.className = 'flex items-center justify-between bg-slate-50 dark:bg-slate-800/40 p-3.5 rounded-xl border border-slate-200 dark:border-slate-850';
			row.innerHTML = `
				<div>
					<span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider ${item.role === 'Depositor' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 border border-blue-200 dark:border-blue-800/30' : 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800/30'}">${item.role}</span>
					<span class="ml-3 text-xs font-bold text-slate-700 dark:text-slate-350">${item.label}</span>
				</div>
				<button type="button" class="remove-roster-item text-slate-400 hover:text-red-500 cursor-pointer bg-transparent border-none font-bold" data-index="${index}">x</button>
			`;
			rosterContainer.appendChild(row);
		});

		// Attach remove listeners
		const removeBtns = rosterContainer.querySelectorAll('.remove-roster-item');
		removeBtns.forEach(btn => {
			btn.addEventListener('click', (e) => {
				const idx = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0', 10);
				roster.splice(idx, 1);
				renderRoster();
				updateThresholdBounds();
			});
		});
	}

	function updateThresholdBounds() {
		const session = getSession();
		const depositorsCount = roster.filter(r => r.role === 'Depositor').length + 1; // self is always depositor
		const beneficiariesCount = roster.filter(r => r.role === 'Beneficiary').length;

		if (depThresholdInput) {
			depThresholdInput.max = depositorsCount.toString();
			if (parseInt(depThresholdInput.value, 10) > depositorsCount) {
				depThresholdInput.value = depositorsCount.toString();
			}
		}
		if (benThresholdInput) {
			benThresholdInput.max = beneficiariesCount.toString();
			if (parseInt(benThresholdInput.value, 10) > beneficiariesCount) {
				benThresholdInput.value = Math.max(1, beneficiariesCount).toString();
			}
		}
	}

	counterpartySelect?.addEventListener('change', () => {
		if (counterpartySelect.value === 'invite-new-counterparty') {
			counterpartySelect.value = '';
			window.dispatchEvent(new CustomEvent('open-invite-modal'));
		}
	});

	window.addEventListener('counterparty-invited', (e: any) => {
		const { email, role } = e.detail;
		
		// Add to counterpartySelect dropdown
		const opt = document.createElement('option');
		opt.value = email;
		opt.text = `${role}: ${email.split('@')[0]} (Invited)`;
		counterpartySelect.add(opt, counterpartySelect.options[1]); // insert after the "invite new" option
		
		// Select the newly invited user in the dropdown
		counterpartySelect.value = email;
		
		// Set the role select matching the invitation role
		if (roleSelect) {
			roleSelect.value = role;
		}

		// Automatically push to the draft roster
		if (!roster.some(item => item.email === email)) {
			roster.push({ email, role: role as 'Depositor' | 'Beneficiary', label: opt.text });
			renderRoster();
			updateThresholdBounds();
		}
	});

	async function loadIdentities() {
		try {
			const identities = await fetchIdentities();
			const session = getSession();
			const currentUserId = session?.identity.damlUserId;

			const identityList = identities || [];

			// Filter counterparties (anyone not me and not a mediator)
			let counterpartyOptions = '<option value="invite-new-counterparty">+ Invite a new email...</option>';
			counterpartyOptions += identityList
				.filter((id: any) => id.damlUserId !== currentUserId && id.role !== 'Mediator')
				.map((id: any) => {
					const emailPrefix = id.email.split('@')[0];
					const shortId = id.damlUserId.substring(0, 12);
					return `<option value="${id.email}">${id.role}: ${emailPrefix} (${shortId}...)</option>`;
				}).join('');
			
			// Filter mediators
			const mediatorOptions = identityList
				.filter((id: any) => id.role === 'Mediator')
				.map((id: any) => {
					const emailPrefix = id.email.split('@')[0];
					return `<option value="${id.damlUserId}">${emailPrefix} (Institutional Mediator)</option>`;
				}).join('');

			if (counterpartySelect) {
				counterpartySelect.innerHTML = counterpartyOptions || '<option value="invite-new-counterparty">+ Invite a new email...</option>';
			}
			if (mediatorSelect) {
				mediatorSelect.innerHTML = mediatorOptions || '<option value="">No mediators found</option>';
			}
			updateThresholdBounds();
		} catch (err) {
			console.error('Failed to load identities', err);
			if (counterpartySelect) counterpartySelect.innerHTML = '<option value="invite-new-counterparty">+ Invite a new email...</option>';
			if (mediatorSelect) mediatorSelect.innerHTML = '<option value="">No mediators found</option>';
		}
	}

	loadIdentities();

	openInviteBtn?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-invite-modal'));
	});

	addBtn?.addEventListener('click', () => {
		const row = container?.firstElementChild?.cloneNode(true) as HTMLElement;
		const inputs = row.querySelectorAll('input');
		inputs.forEach(i => i.value = '');
		container?.appendChild(row);
		attachRemoveEvent(row);
	});

	function attachRemoveEvent(row: HTMLElement) {
		const btn = row.querySelector('.remove-milestone');
		btn?.addEventListener('click', () => {
			if (container?.children.length && container.children.length > 1) {
				row.remove();
			}
		});
	}

	if (container?.firstElementChild) {
		attachRemoveEvent(container.firstElementChild as HTMLElement);
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const session = getSession();
		
		const labels = formData.getAll('m-label');
		const amounts = formData.getAll('m-amount');
		const milestones = labels.map((l, i) => ({
			label: l.toString(),
			amount: parseFloat(amounts[i].toString()),
			completed: false
		}));

		const totalAmount = milestones.reduce((sum, m) => sum + m.amount, 0);

		let payload = {};
		try {
			payload = JSON.parse(formData.get('payload')?.toString() || '{}');
		} catch (err) {
			alert('Invalid JSON in payload');
			return;
		}

		const schemaUrl = formData.get('schemaUrl')?.toString();
		let contractType = 'Corporate';
		if (schemaUrl?.includes('grants')) contractType = 'Corporate';
		else if (schemaUrl?.includes('leasing')) contractType = 'RealEstate';
		else if (schemaUrl?.includes('supply-chain')) contractType = 'ImportExport';

		const depositors = [session?.identity.email, ...roster.filter(item => item.role === 'Depositor').map(item => item.email)].filter(Boolean);
		const beneficiaries = roster.filter(item => item.role === 'Beneficiary').map(item => item.email);

		const depThreshold = parseInt(formData.get('depositorThreshold')?.toString() || '1', 10);
		const benThreshold = parseInt(formData.get('beneficiaryThreshold')?.toString() || '1', 10);

		if (beneficiaries.length === 0) {
			alert('At least one beneficiary is required in the Roster.');
			return;
		}

		const req = {
			beneficiaryEmail: beneficiaries[0],
			mediator: formData.get('mediator'),
			contractType: contractType,
			amount: totalAmount,
			currency: formData.get('currency'),
			terms: {
				milestones: milestones,
				conditionDescription: milestones.map(m => `${m.label}: ${m.amount}`).join(', '),
				expiryDate: new Date(Date.now() + 86400000 * 30).toISOString()
			},
			metadata: {
				...payload,
				depositors: depositors,
				depositorThreshold: depThreshold,
				beneficiaries: beneficiaries,
				beneficiaryThreshold: benThreshold
			}
		};

		try {
			await saveDraft(req);
			alert('Draft agreement authoritatively saved.');
			window.location.href = '/';
		} catch (err: any) {
			alert('Failed to save draft: ' + err.message);
		}
	});
</script>
