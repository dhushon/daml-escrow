---
import Layout from '../layouts/Layout.astro';
import RefreshSlider from '../components/RefreshSlider.astro';
import { fetchMetrics, fetchConfig } from '../lib/api';

const adminCookie = Astro.cookies.get('admin-mode');
const isAdmin = adminCookie?.value === 'true';
const targetUser = isAdmin ? 'CentralBank' : 'Buyer';

let metrics = null;
let error = null;
let initialInterval = 8; // Default 8s

try {
	metrics = await fetchMetrics(targetUser);
	const config = await fetchConfig(targetUser, 'refreshIntervalExp');
	if (config && typeof config.value === 'number') {
		initialInterval = Math.pow(2, config.value);
	}
} catch (e) {
	error = e.message;
}

// Simple SVG Graph Helper
const generateGraphPoints = (history: any[]) => {
	const data = history || [];
	if (data.length === 0) return "";
	const max = Math.max(...data.map(h => h.count), 1);
	const width = 400;
	const height = 100;
	return data.map((h, i) => {
		const x = (i / (data.length - 1)) * width;
		const y = height - (h.count / max) * height;
		return `${x},${y}`;
	}).join(" ");
};
---

<Layout title="Platform Metrics | Stablecoin Escrow">
	<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
		<div>
			<div class="flex items-center space-x-2 mb-1">
				<span class={`w-2 h-2 rounded-full ${isAdmin ? 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]' : 'bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]'}`}></span>
				<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
					{isAdmin ? 'System-Wide Ledger Metrics' : 'Personal Escrow Analytics'}
				</span>
			</div>
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">
				{isAdmin ? 'Total Escrows & Oversight' : 'My Financial Activity'}
			</h2>
		</div>
		<div class="w-full md:w-64">
			<RefreshSlider />
		</div>
	</div>

	{error && (
		<div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 mb-8 rounded-r-xl font-mono transition-colors">
			<p class="text-sm font-bold text-red-700 dark:text-red-400">Error: {error}</p>
		</div>
	)}

	{metrics && (
		<div class="space-y-12 pb-12">
			{/* Section 1: Escrow Metrics */}
			<section>
				<div class="flex justify-between items-center mb-6">
					<h3 class="text-lg font-bold text-slate-800 dark:text-white">Escrow Metrics</h3>
					<span class="text-[10px] font-bold text-slate-400 uppercase bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">Real-Time Ledger</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors">
						<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Active Escrows</p>
						<p class="text-4xl font-black mt-2 text-blue-600 dark:text-blue-400">{metrics.totalActiveEscrows}</p>
					</div>
					
					<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors">
						<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Value in Escrow</p>
						<p class="text-4xl font-black mt-2 text-slate-900 dark:text-white tracking-tighter">
							{metrics.totalValueInEscrow.toLocaleString()} 
							<span class="text-xs font-medium text-slate-400 italic">USD</span>
						</p>
					</div>

					<div class="col-span-1 md:col-span-2 bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
						<div class="flex justify-between items-start mb-4">
							<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest whitespace-nowrap">Escrow Trend</p>
							<div class="flex space-x-1">
								{metrics.activityHistory ? metrics.activityHistory.map((h: any) => (
									<div class="w-1 bg-blue-500/20 h-4 rounded-full overflow-hidden flex flex-col justify-end">
										<div class="w-full bg-blue-500" style={`height: ${(h.count / Math.max(...metrics.activityHistory.map((x:any)=>x.count), 1)) * 100}%`}></div>
									</div>
								)) : null}
							</div>
						</div>
						<div class="h-16 w-full overflow-hidden">
							<svg viewBox="0 0 400 100" class="w-full h-full overflow-visible">
								<polyline
									fill="none"
									stroke="#3b82f6"
									stroke-width="3"
									stroke-linecap="round"
									stroke-linejoin="round"
									points={generateGraphPoints(metrics.activityHistory)}
								/>
								<path
									fill="url(#lineGradientBlue)"
									d={`M 0,100 L ${generateGraphPoints(metrics.activityHistory)} L 400,100 Z`}
								/>
								<defs>
									<linearGradient id="lineGradientBlue" x1="0" y1="0" x2="0" y2="1">
										<stop offset="0%" stop-color="#3b82f6" stop-opacity="0.2" />
										<stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
									</linearGradient>
								</defs>
							</svg>
						</div>
						<div class="flex justify-between mt-2">
							<span class="text-[8px] font-bold text-slate-400">{metrics.activityHistory && metrics.activityHistory.length > 0 ? metrics.activityHistory[0].date : ''}</span>
							<span class="text-[8px] font-bold text-slate-400">{metrics.activityHistory && metrics.activityHistory.length > 0 ? metrics.activityHistory[metrics.activityHistory.length-1].date : ''}</span>
						</div>
					</div>
				</div>
			</section>

			{/* Section 2: Ledger Health & Throughput */}
			<section>
				<h3 class="text-lg font-bold text-slate-800 dark:text-white mb-6">Ledger Health & Throughput</h3>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="col-span-1 md:col-span-2 bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
						<div class="flex justify-between items-start mb-4">
							<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest whitespace-nowrap">Transaction Throughput (TPS)</p>
							<span class="text-[10px] font-black text-green-500">{metrics.ledgerHealth.tps} TPS</span>
						</div>
						<div class="h-16 w-full overflow-hidden">
							<svg viewBox="0 0 400 100" class="w-full h-full overflow-visible">
								<polyline
									fill="none"
									stroke="#10b981"
									stroke-width="3"
									stroke-linecap="round"
									stroke-linejoin="round"
									points={generateGraphPoints(metrics.tpsHistory)}
								/>
								<path
									fill="url(#lineGradientGreen)"
									d={`M 0,100 L ${generateGraphPoints(metrics.tpsHistory)} L 400,100 Z`}
								/>
								<defs>
									<linearGradient id="lineGradientGreen" x1="0" y1="0" x2="0" y2="1">
										<stop offset="0%" stop-color="#10b981" stop-opacity="0.2" />
										<stop offset="100%" stop-color="#10b981" stop-opacity="0" />
									</linearGradient>
								</defs>
							</svg>
						</div>
						<div class="flex justify-between mt-2">
							<span class="text-[8px] font-bold text-slate-400">{metrics.tpsHistory && metrics.tpsHistory.length > 0 ? metrics.tpsHistory[0].date : ''}</span>
							<span class="text-[8px] font-bold text-slate-400">{metrics.tpsHistory && metrics.tpsHistory.length > 0 ? metrics.tpsHistory[metrics.tpsHistory.length-1].date : ''}</span>
						</div>
					</div>

					<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors">
						<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Command Success</p>
						<p class="text-4xl font-black mt-2 text-green-600 dark:text-green-400">{metrics.ledgerHealth.commandSuccessRate}%</p>
						<p class="text-[8px] font-bold text-slate-400 uppercase mt-1">Submission Reliability</p>
					</div>

					<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm transition-colors text-right">
						<p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Total ACS Size</p>
						<p class="text-4xl font-black mt-2 text-slate-900 dark:text-white">{metrics.ledgerHealth.activeContracts}</p>
						<p class="text-[8px] font-bold text-slate-400 uppercase mt-1">Active Contract Set</p>
					</div>
				</div>
			</section>

			{/* Section 3: API & System Performance */}
			<section>
				<div class="flex justify-between items-center mb-6">
					<h3 class="text-lg font-bold text-slate-800 dark:text-white">API & System Performance</h3>
					<span class="text-[10px] font-bold text-green-500 uppercase tracking-widest flex items-center">
						<span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-2 animate-ping shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
						Nodes Healthy
					</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800">
						<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Avg Latency</p>
						<p class="text-2xl font-black mt-1 text-slate-800 dark:text-white">{metrics.systemPerformance.apiLatencyMs} <span class="text-xs font-normal text-slate-400 italic">ms</span></p>
					</div>
					<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800">
						<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">P95 / P99</p>
						<p class="text-2xl font-black mt-1 text-slate-800 dark:text-white">
							{metrics.systemPerformance.p95LatencyMs} <span class="text-slate-300">/</span> {metrics.systemPerformance.p99LatencyMs}
							<span class="text-xs font-normal text-slate-400 italic ml-1">ms</span>
						</p>
					</div>
					<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800 transition-all hover:border-blue-500/30">
						<div class="flex justify-between items-center mb-3">
							<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">CPU Load</p>
							<span class="text-xs font-black text-slate-800 dark:text-white">{metrics.systemPerformance.cpuUsage.toFixed(1)}%</span>
						</div>
						<div class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
							<div class="bg-blue-500 h-full transition-all duration-1000" style={`width: ${metrics.systemPerformance.cpuUsage}%`}></div>
						</div>
					</div>

					<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800 transition-all hover:border-blue-500/30">
						<div class="flex justify-between items-center mb-3">
							<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Memory Usage</p>
							<span class="text-xs font-black text-slate-800 dark:text-white">{metrics.systemPerformance.memoryUsage.toFixed(1)} <span class="text-[8px] text-slate-400 uppercase">MB</span></span>
						</div>
						<div class="w-full bg-slate-100 dark:bg-slate-800 h-1.5 rounded-full overflow-hidden">
							<div class="bg-indigo-500 h-full transition-all duration-1000" style="width: 45%"></div>
						</div>
					</div>
				</div>
			</section>
		</div>
	)}

	{isAdmin && (
		<div class="mt-12 bg-slate-900 dark:bg-blue-950 rounded-3xl p-10 text-white shadow-2xl relative overflow-hidden transition-colors duration-500 border border-slate-800 dark:border-blue-900">
			<div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
				<div class="max-w-2xl">
					<h3 class="text-3xl font-black mb-4 tracking-tight">Central Bank Oversight</h3>
					<p class="text-slate-300 dark:text-blue-200 leading-relaxed font-medium">
						This unified dashboard provides absolute visibility into stablecoin obligations. 
						As the issuer, the Central Bank monitors systemic liquidity and ensures that every escrowed token is backed and settled with cryptographic certainty.
					</p>
				</div>
				<div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 inline-block self-start md:self-center">
					<div class="flex items-center space-x-4">
						<div class="w-3 h-3 bg-green-400 rounded-full animate-pulse shadow-[0_0_12px_rgba(74,222,128,0.5)]"></div>
						<span class="text-sm font-bold uppercase tracking-wider">System Status: Nominal</span>
					</div>
				</div>
			</div>
			<div class="absolute right-0 bottom-0 opacity-[0.03] dark:opacity-[0.05] translate-y-1/4 translate-x-1/4 scale-150 text-white">
				<img src="/favicon.svg" alt="" class="w-96 h-96 invert" />
			</div>
		</div>
	)}
</Layout>

<script is:inline define:vars={{ initialInterval }}>
	let intervalTime = initialInterval * 1000;
	let pulseInterval;

	function startPulse() {
		if (pulseInterval) clearInterval(pulseInterval);
		pulseInterval = setInterval(() => {
			if (!document.hidden) {
				window.location.reload();
			}
		}, intervalTime);
	}

	window.addEventListener('refresh-interval-change', (e) => {
		intervalTime = e.detail.seconds * 1000;
		console.log('Refresh pulse adjusted to:', intervalTime, 'ms');
		startPulse();
	});

	document.addEventListener('visibilitychange', () => {
		if (document.hidden) clearInterval(pulseInterval);
		else startPulse();
	});

	startPulse();
</script>
