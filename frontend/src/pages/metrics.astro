---
import Layout from '../layouts/Layout.astro';
import RefreshSlider from '../components/RefreshSlider.astro';
---

<Layout title="Platform Metrics | Stablecoin Escrow">
	<div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
		<div>
			<div class="flex items-center space-x-2 mb-1">
				<span id="role-indicator" class="w-2 h-2 rounded-full bg-slate-300"></span>
				<span id="role-label" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
					Synchronizing...
				</span>
			</div>
			<h2 id="metrics-title" class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">
				Financial Activity
			</h2>
		</div>
		<div class="w-full md:w-64">
			<RefreshSlider />
		</div>
	</div>

	<div id="metrics-content" class="opacity-0 transition-opacity duration-500 py-20 text-center text-slate-400 italic font-medium">
		Retrieving ledger analytics...
	</div>

	<div id="admin-notice" class="hidden mt-12 bg-slate-900 dark:bg-blue-950 rounded-3xl p-10 text-white shadow-2xl relative overflow-hidden transition-colors duration-500 border border-slate-800 dark:border-blue-900">
		<div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
			<div class="max-w-2xl">
				<h3 class="text-3xl font-black mb-4 tracking-tight">Central Bank Oversight</h3>
				<p class="text-slate-300 dark:text-blue-200 leading-relaxed font-medium">
					This unified dashboard provides absolute visibility into stablecoin obligations. 
					As the issuer, the Central Bank monitors systemic liquidity and ensures that every escrowed token is backed and settled with cryptographic certainty.
				</p>
			</div>
			<div class="bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10 inline-block self-start md:self-center">
				<div class="flex items-center space-x-4">
					<div class="w-3 h-3 bg-green-400 rounded-full animate-pulse shadow-[0_0_12px_rgba(74,222,128,0.5)]"></div>
					<span class="text-sm font-bold uppercase tracking-wider">System Status: Nominal</span>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	import { fetchMetrics } from '../lib/api';
	import { getSession } from '../lib/auth';

	async function init() {
		const session = getSession();
		const content = document.getElementById('metrics-content');
		const indicator = document.getElementById('role-indicator');
		const label = document.getElementById('role-label');
		const title = document.getElementById('metrics-title');
		const adminNotice = document.getElementById('admin-notice');

		if (!content) return;

		try {
			const metrics = await fetchMetrics();
			const isAdmin = session?.scopes.includes('system:admin');

			// Update Headers
			if (isAdmin) {
				indicator?.classList.replace('bg-slate-300', 'bg-blue-500');
				if (label) label.textContent = 'System-Wide Ledger Metrics';
				if (title) title.textContent = 'Total Escrows & Oversight';
				adminNotice?.classList.remove('hidden');
			} else {
				indicator?.classList.replace('bg-slate-300', 'bg-green-500');
				if (label) label.textContent = 'Personal Escrow Analytics';
				if (title) title.textContent = 'My Financial Activity';
			}

			// Render Metrics
			content.innerHTML = `
				<div class="space-y-12 pb-12 text-left">
					<section>
						<div class="flex justify-between items-center mb-6">
							<h3 class="text-lg font-bold text-slate-800 dark:text-white">Escrow Metrics</h3>
							<span class="text-[10px] font-bold text-slate-400 uppercase bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">Real-Time Ledger</span>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
							<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
								<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Active Escrows</p>
								<p class="text-4xl font-black mt-2 text-blue-600 dark:text-blue-400">${metrics.totalActiveEscrows}</p>
							</div>
							<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
								<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Value in Escrow</p>
								<p class="text-4xl font-black mt-2 text-slate-900 dark:text-white tracking-tighter">
									${metrics.totalValueInEscrow.toLocaleString()} 
									<span class="text-xs font-medium text-slate-400 italic">USD</span>
								</p>
							</div>
						</div>
					</section>

					<section>
						<h3 class="text-lg font-bold text-slate-800 dark:text-white mb-6">API & System Performance</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
							<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800">
								<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Avg Latency</p>
								<p class="text-2xl font-black mt-1 text-slate-800 dark:text-white">${metrics.systemPerformance.apiLatencyMs} <span class="text-xs font-normal text-slate-400 italic">ms</span></p>
							</div>
							<div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-200 dark:border-slate-800">
								<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">CPU Load</p>
								<p class="text-2xl font-black mt-1 text-slate-800 dark:text-white">${metrics.systemPerformance.cpuUsage.toFixed(1)}%</p>
							</div>
						</div>
					</section>
				</div>
			`;
			content.classList.remove('opacity-0');

		} catch (err) {
			content.innerHTML = `<div class="py-20 text-center text-red-500 font-mono text-xs">Sync Error: ${err.message}</div>`;
			content.classList.remove('opacity-0');
		}
	}

	init();
</script>
