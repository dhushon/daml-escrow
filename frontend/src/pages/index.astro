---
import Layout from '../layouts/Layout.astro';
import EscrowCard from '../components/EscrowCard.astro';
import InviteModal from '../components/InviteModal.astro';
import { fetchEscrows, fetchProposals, fetchDrafts } from '../lib/api';

const userEmail = Astro.cookies.get('user_email')?.value;
const userScopes = (Astro.cookies.get('user_scopes')?.value || '').split(',');
const isAuthenticated = !!userEmail;

const adminCookie = Astro.cookies.get('admin-mode');
const hasAdminScope = userScopes.includes('system:admin');
const assumedRole = Astro.cookies.get('assumed_role')?.value || 'Depositor';
const view = assumedRole;

// Only act as Admin/System-Wide Oversight if they have the scope AND assumed CentralBank or EscrowMediator role
const isAdmin = (adminCookie?.value === 'true' || hasAdminScope) && (view === 'CentralBank' || view === 'EscrowMediator');

const tab = Astro.url.searchParams.get('tab') || 'active';

// Determine Effective Role for UI
let effectiveRole = 'Guest';
if (isAdmin) {
        effectiveRole = view === 'CentralBank' ? 'Issuer' : 'Mediator';
} else {
        effectiveRole = view;
}

let escrows = [];
let proposals = [];
let drafts = [];
let error = null;

if (isAuthenticated) {
    try {
        escrows = await fetchEscrows(userEmail, assumedRole);
        proposals = await fetchProposals(userEmail, assumedRole);
        drafts = await fetchDrafts(userEmail, assumedRole);
    } catch (err) {
        error = err.message;
    }
}
---
<Layout title="Dashboard | Stablecoin Escrow">
	{!isAuthenticated ? (
		/* Public Landing Page */
		<div class="max-w-4xl mx-auto py-20 text-center animate-fade-in">
			<div class="inline-flex items-center space-x-2 px-3 py-1 bg-brand-500/10 text-brand-500 rounded-full text-[10px] font-black uppercase tracking-widest mb-8 border border-brand-500/20">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
				</span>
				<span>High-Assurance Financial Infrastructure</span>
			</div>
			<h1 class="text-5xl md:text-7xl font-black text-slate-900 dark:text-white tracking-tighter mb-6">
				Privacy-Preserving <br/><span class="text-brand-500">Stablecoin Escrows</span>
			</h1>
			<p class="text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-12">
				A high-assurance platform powered by Daml smart contracts and Canton distributed ledgers. 
				Secure your digital assets with programmatic multi-party settlement.
			</p>
			
			<div class="flex flex-col md:flex-row justify-center gap-4">
				<a href="/login" class="bg-brand-600 hover:bg-brand-700 text-white font-black py-4 px-8 rounded-2xl shadow-xl shadow-brand-600/20 transition-all transform active:scale-95 text-lg">
					Get Started
				</a>
				<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold py-4 px-8 rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-lg cursor-pointer">
					View Documentation
				</button>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-24">
				<div class="p-6 glass-card rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm transition-all duration-300 hover:scale-[1.02]">
					<div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04 M12 21.75c-2.676 0-5.216-.584-7.499-1.632A12.02 12.02 0 013 12c0-5.392 3.478-9.938 8.288-11.538.356-.108.74-.108 1.096 0A11.977 11.955 0 0121 12c0 5.392-3.478 9.938-8.288 11.538-.356.108-.74.108-1.096 0z" /></svg>
					</div>
					<h3 class="font-black text-slate-900 dark:text-white uppercase tracking-tight mb-2 text-sm">Immutable Logic</h3>
					<p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Escrow terms enforced by cryptographically signed Daml bytecode.</p>
				</div>
				<div class="p-6 glass-card rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm transition-all duration-300 hover:scale-[1.02]">
					<div class="w-12 h-12 bg-brand-500/10 rounded-2xl flex items-center justify-center text-brand-500 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
					</div>
					<h3 class="font-black text-slate-900 dark:text-white uppercase tracking-tight mb-2 text-sm">Sovereign Data</h3>
					<p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Distributed multi-node architecture ensures no single party controls your data.</p>
				</div>
				<div class="p-6 glass-card rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm transition-all duration-300 hover:scale-[1.02]">
					<div class="w-12 h-12 bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-500 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
					</div>
					<h3 class="font-black text-slate-900 dark:text-white uppercase tracking-tight mb-2 text-sm">Instant Settlement</h3>
					<p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Automated milestone verification via trusted Oracles and stablecoin rails.</p>
				</div>
			</div>
		</div>
	) : (
		/* Authenticated Dashboard */
		<div id="dashboard-content" class="animate-fade-in">
			<div class="mb-8 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
				<div>
					<div class="flex items-center space-x-2 mb-1.5">
						<span id="role-indicator" class={`w-2 h-2 rounded-full ${isAdmin ? 'bg-brand-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]' : 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]'}`}></span>
						<span id="role-label" class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">
							{isAdmin ? 'System-Wide Oversight' : `${view} Perspective`}
						</span>
					</div>
					<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Escrow Dashboard</h2>
				</div>
				
			</div>

			<div class="flex border-b border-slate-200 dark:border-slate-800/80 mb-8 overflow-x-auto gap-2">
				<a 
					href={`/?tab=active`} 
					class={`pb-4 px-6 text-[10px] font-black uppercase tracking-widest transition-all border-b-2 ${tab === 'active' ? 'border-brand-500 text-brand-500' : 'border-transparent text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
				>
					Active Contracts
				</a>
				<a
					href={`/?tab=proposals`}
					class={`pb-4 px-6 text-[10px] font-black uppercase tracking-widest transition-all border-b-2 ${tab === 'proposals' ? 'border-brand-500 text-brand-500' : 'border-transparent text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
				>
					Pending Proposals
				</a>
				<a
					href={`/?tab=negotiations`}
					class={`pb-4 px-6 text-[10px] font-black uppercase tracking-widest transition-all border-b-2 ${tab === 'negotiations' ? 'border-brand-500 text-brand-500' : 'border-transparent text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
				>
					Negotiations
				</a>
			</div>
			
			{error && (
				<div class="bg-rose-500/10 border-l-4 border-rose-500 p-4 mb-8 rounded-r-2xl transition-colors font-mono">
					<p class="text-xs font-black text-rose-500">Connection Error: {error}</p>
				</div>
			)}

			{tab === 'active' ? (
				(escrows || []).length === 0 && !error ? (
					<div class="text-center py-20 glass-card rounded-3xl border border-dashed border-slate-200 dark:border-slate-800">
						<div class="mx-auto w-12 h-12 text-slate-300 dark:text-slate-700 mb-4">
							<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3"></path></svg>
						</div>
						<h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">No active escrows</h4>
						<p class="text-xs text-slate-400 dark:text-slate-500 mt-2 max-w-sm mx-auto">Agreements will appear here once proposals are accepted.</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{(escrows || []).filter(e => e !== null).map(e => <EscrowCard escrow={e} isAdmin={isAdmin} userRole={effectiveRole} />)}
					</div>
				)
			) : tab === 'proposals' ? (
				(proposals || []).length === 0 && !error ? (
					<div class="text-center py-20 glass-card rounded-3xl border border-dashed border-slate-200 dark:border-slate-800">
						<div class="mx-auto w-12 h-12 text-slate-300 dark:text-slate-700 mb-4">
							<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0018 4.5h-3m-9 0H3A2.25 2.25 0 00.75 6.75V19.5A2.25 2.25 0 003 21.75h9.75M9 10.5c0 .28.22.5.5.5h.5c.28 0 .5-.22.5-.5a.5.5 0 00-.5-.5h-.5a.5.5 0 00-.5.5zm.5 2.5a.5.5 0 000 1h.5a.5.5 0 000-1h-.5zm0 3a.5.5 0 000 1h.5a.5.5 0 000-1h-.5zM15 7h3a1 1 0 011 1v11a1 1 0 01-1 1h-3m-6 0H6a1 1 0 01-1-1V8a1 1 0 011-1h3m0-3.5h6" /></svg>
						</div>
						<h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">No pending proposals</h4>
						<p class="text-xs text-slate-400 dark:text-slate-500 mt-2 max-w-sm mx-auto">New agreement offers will appear here for review.</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{(proposals || []).filter(e => e !== null).map(p => (
							<div class="glass-card interactive-card rounded-3xl p-6 flex flex-col justify-between h-full">
								<div>
									<div class="flex justify-between items-start mb-4">
										<span class="text-[9px] font-black text-brand-500 uppercase tracking-widest bg-brand-500/10 px-2.5 py-1.5 rounded-xl border border-brand-500/10">Proposal</span>
										<p class="text-sm font-black text-brand-500">{p.asset.amount.toLocaleString()} <span class="text-[10px] text-slate-400">{p.asset.currency}</span></p>
									</div>
									<code class="text-[10px] text-slate-400 font-mono block truncate mb-4">ID: {p.id.substring(0, 16)}...</code>
									
									<div class="space-y-2 mb-6 border-t border-slate-100/50 dark:border-slate-800/40 pt-4">
										<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Parties</p>
										<div class="flex justify-between items-center text-[10px] bg-slate-50/50 dark:bg-slate-800/10 p-2 rounded-xl border border-slate-100/50 dark:border-slate-800/20">
											<span class="text-slate-500 dark:text-slate-400">Depositor:</span>
											<span class="font-black text-slate-700 dark:text-slate-300">{p.depositor.split('::')[0]}</span>
										</div>
										<div class="flex justify-between items-center text-[10px] bg-slate-50/50 dark:bg-slate-800/10 p-2 rounded-xl border border-slate-100/50 dark:border-slate-800/20">
											<span class="text-slate-500 dark:text-slate-400">Beneficiary:</span>
											<span class="font-black text-slate-700 dark:text-slate-300">{p.beneficiary.split('::')[0]}</span>
										</div>
									</div>
								</div>

								{view === 'Beneficiary' && (
									<div class="flex gap-2">
										<button 
											data-action="accept" 
											data-id={p.id}
											class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white py-3 rounded-2xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-95 shadow-md shadow-emerald-500/20 cursor-pointer border-none"
										>
											Accept & Sign
										</button>
									</div>
								)}
							</div>
						))}
					</div>
				)
			) : (
				/* Negotiations Tab */
				(drafts || []).length === 0 && !error ? (
					<div class="text-center py-20 glass-card rounded-3xl border border-dashed border-slate-200 dark:border-slate-800">
						<div class="mx-auto w-12 h-12 text-slate-300 dark:text-slate-700 mb-4">
							<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25-9 3.694-9 8.25c0 1.583.473 3.06 1.288 4.305l-.947 3.447 3.618-.894a9.14 9.14 0 005.041 1.392z" /></svg>
						</div>
						<h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">No active negotiations</h4>
						<p class="text-xs text-slate-400 dark:text-slate-500 mt-2 max-w-sm mx-auto">Start a new draft agreement to begin the escrow process.</p>
						<div class="flex justify-center gap-4 mt-6">
							<a href="/compose" class="bg-brand-600 text-white px-6 py-3 rounded-2xl text-[10px] font-black tracking-wider uppercase hover:bg-brand-700 transition-all hover:scale-[1.02] shadow-xl shadow-brand-500/20">Compose Draft</a>
						</div>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{(drafts || []).map(draft => (
							<a href={`/negotiate/${draft.rootId}`} class="glass-card interactive-card rounded-3xl p-6 hover:shadow-xl transition-all group relative overflow-hidden flex flex-col justify-between h-full decoration-none">
								<div>
									<div class="flex justify-between items-start mb-4">
										<div class="p-2.5 bg-brand-500/10 rounded-2xl text-brand-500">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
										</div>
										<span class="bg-brand-500/10 text-brand-500 text-[9px] font-black px-2.5 py-1.5 rounded-full uppercase tracking-widest border border-brand-500/10">{draft.status}</span>
									</div>
									<h4 class="font-black text-slate-900 dark:text-white uppercase tracking-tight truncate mb-1">{draft.beneficiaryEmail}</h4>
									<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Initiator: {draft.initiatorRole}</p>
								</div>
								
								<div>
									<div class="my-5 py-3 border-y border-slate-100/50 dark:border-slate-800/40 flex items-end justify-between">
										<div>
											<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Amount</p>
											<p class="text-lg font-black text-slate-900 dark:text-white leading-none">{draft.amount.toLocaleString()} <span class="text-xs text-slate-400 font-bold">{draft.currency}</span></p>
										</div>
										<div class="text-right">
											<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Version</p>
											<p class="text-sm font-black text-slate-700 dark:text-slate-300">V{draft.version}</p>
										</div>
									</div>
									<div class="pt-2 flex justify-between items-center">
										<code class="text-[9px] font-bold text-slate-400 font-mono">ID: {draft.rootId.substring(0,8)}...</code>
										<span class="text-brand-500 font-black text-[10px] tracking-wider uppercase group-hover:translate-x-1 transition-transform inline-flex items-center">
											Negotiate <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" /></svg>
										</span>
									</div>
								</div>
							</a>
						))}
					</div>
				)
			)}
		</div>
	)}

	<InviteModal />
</Layout>

<script>
	import { 
		confirmConditions, 
		raiseDispute, 
		fundEscrow, 
		activateEscrow, 
		ratifySettlement, 
		finalizeSettlement 
	} from '../lib/api';
	import { getSession } from '../lib/auth';

	// Client-side Hydration & Role Check
	const session = getSession();
	if (session) {
		const isAdmin = session.scopes.includes('system:admin');
		if (isAdmin) {
			document.cookie = "admin-mode=true; path=/; max-age=3600";
		} else {
			document.cookie = "admin-mode=false; path=/; max-age=3600";
		}
	}

	const buttons = document.querySelectorAll('button[data-action]');
	buttons.forEach(btn => {
		btn.addEventListener('click', async (e) => {
			const target = e.currentTarget as HTMLButtonElement;
			const action = target.getAttribute('data-action');
			const id = target.getAttribute('data-id');
			if (!id) return;

			const session = getSession();
			const user = session?.assumedRole || 'Depositor';

			const originalText = target.textContent;
			target.disabled = true;
			target.textContent = 'Processing...';

			try {
				if (action === 'fund') {
					const ref = prompt("Enter Custody Reference (e.g. TX-123):", "TX-" + Math.floor(Math.random()*1000));
					if (ref) await fundEscrow(id, ref);
					else throw new Error("Reference required");
				}
				else if (action === 'activate') await activateEscrow(id);
				else if (action === 'confirm') await confirmConditions(id);
				else if (action === 'dispute') await raiseDispute(id);
				else if (action === 'ratify') await ratifySettlement(id);
				else if (action === 'disburse') await finalizeSettlement(id);
				
				window.location.reload();
			} catch (err) {
				alert('Action failed: ' + err.message);
				target.disabled = false;
				target.textContent = originalText;
			}
		});
	});

	document.getElementById('open-invite')?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-invite-modal'));
	});
</script>
