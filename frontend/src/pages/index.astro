---
import Layout from '../layouts/Layout.astro';
import EscrowCard from '../components/EscrowCard.astro';
import InviteModal from '../components/InviteModal.astro';
import { fetchEscrows, fetchProposals } from '../lib/api';

const userEmail = Astro.cookies.get('user_email')?.value;
const userScopes = (Astro.cookies.get('user_scopes')?.value || '').split(',');
const isAuthenticated = !!userEmail;

const adminCookie = Astro.cookies.get('admin-mode');
const isAdmin = adminCookie?.value === 'true' || userScopes.includes('system:admin');

const view = Astro.url.searchParams.get('view') || 'Buyer';
const tab = Astro.url.searchParams.get('tab') || 'active';

// Determine Effective Role for UI
let effectiveRole = 'Guest';
if (userScopes.includes('system:admin')) {
	effectiveRole = view === 'Buyer' ? 'Issuer' : 'Mediator';
} else if (userScopes.includes('escrow:write')) {
	effectiveRole = view;
}

let escrows = [];
let proposals = [];
let error = null;
---

<Layout title="Dashboard | Stablecoin Escrow">
	{!isAuthenticated ? (
		/* Public Landing Page */
		<div class="max-w-4xl mx-auto py-20 text-center">
			<div class="inline-flex items-center space-x-2 px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-full text-[10px] font-black uppercase tracking-widest mb-8 border border-blue-100 dark:border-blue-800">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
				</span>
				<span>High-Assurance Financial Infrastructure</span>
			</div>
			<h1 class="text-5xl md:text-7xl font-black text-slate-900 dark:text-white tracking-tighter mb-6">
				Privacy-Preserving <br/><span class="text-blue-600">Stablecoin Escrows</span>
			</h1>
			<p class="text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed mb-12">
				A high-assurance platform powered by Daml smart contracts and Canton distributed ledgers. 
				Secure your digital assets with programmatic multi-party settlement.
			</p>
			
			<div class="flex flex-col md:flex-row justify-center gap-4">
				<a href="/login" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-2xl shadow-xl shadow-blue-500/30 transition-all transform active:scale-95 text-lg">
					Get Started
				</a>
				<button class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold py-4 px-8 rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-lg">
					View Documentation
				</button>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-24">
				<div class="p-6 bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm">
					<div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center text-green-600 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04 \
						M12 21.75c-2.676 0-5.216-.584-7.499-1.632A12.02 12.02 0 013 12c0-5.392 3.478-9.938 8.288-11.538.356-.108.74-.108 1.096 0A11.977 11.955 0 0121 12c0 5.392-3.478 9.938-8.288 11.538-.356.108-.74.108-1.096 0z" /></svg>
					</div>
					<h3 class="font-bold text-slate-900 dark:text-white mb-2">Immutable Logic</h3>
					<p class="text-sm text-slate-500">Escrow terms enforced by cryptographically signed Daml bytecode.</p>
				</div>
				<div class="p-6 bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm">
					<div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center text-blue-600 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
					</div>
					<h3 class="font-bold text-slate-900 dark:text-white mb-2">Sovereign Data</h3>
					<p class="text-sm text-slate-500">Distributed multi-node architecture ensures no single party controls your data.</p>
				</div>
				<div class="p-6 bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-sm">
					<div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center text-purple-600 mb-4">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
					</div>
					<h3 class="font-bold text-slate-900 dark:text-white mb-2">Instant Settlement</h3>
					<p class="text-sm text-slate-500">Automated milestone verification via trusted Oracles and stablecoin rails.</p>
				</div>
			</div>
		</div>
	) : (
		/* Authenticated Dashboard */
		<div id="dashboard-content">
			<div class="mb-8 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
				<div>
					<div class="flex items-center space-x-2 mb-1">
						<span id="role-indicator" class={`w-2 h-2 rounded-full ${isAdmin ? 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]' : 'bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]'}`}></span>
						<span id="role-label" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
							{isAdmin ? 'System-Wide Oversight' : `${view} Perspective`}
						</span>
					</div>
					<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Escrow Dashboard</h2>
				</div>
				
				<div class="flex items-center space-x-4">
					<div id="view-toggle" class={`inline-flex bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-1 shadow-sm transition-colors text-[10px] font-black uppercase tracking-widest ${isAdmin ? 'hidden' : ''}`}>
						<a href={`/?view=Buyer&tab=${tab}`} class={`px-4 py-1.5 rounded-lg transition-all ${view === 'Buyer' ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-slate-400 hover:text-slate-900 dark:hover:text-white'}`}>Buyer</a>
						<a href={`/?view=Seller&tab=${tab}`} class={`px-4 py-1.5 rounded-lg transition-all ${view === 'Seller' ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-slate-400 hover:text-slate-900 dark:hover:text-white'}`}>Seller</a>
					</div>
				</div>
			</div>

			<div class="flex border-b border-slate-200 dark:border-slate-800 mb-8 overflow-x-auto">
				<a 
					href={`/?view=${view}&tab=active`} 
					class={`pb-4 px-6 text-xs font-bold uppercase tracking-widest transition-all border-b-2 ${tab === 'active' ? 'border-blue-600 text-blue-600' : 'border-transparent text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
				>
					Active Contracts
				</a>
				<a 
					href={`/?view=${view}&tab=proposals`} 
					class={`pb-4 px-6 text-xs font-bold uppercase tracking-widest transition-all border-b-2 ${tab === 'proposals' ? 'border-blue-600 text-blue-600' : 'border-transparent text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
				>
					Pending Proposals
				</a>
			</div>

			{error && (
				<div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 mb-8 rounded-r-xl transition-colors font-mono">
					<p class="text-sm font-bold text-red-700 dark:text-red-400">Connection Error: {error}</p>
				</div>
			)}

			{tab === 'active' ? (
				(escrows || []).length === 0 && !error ? (
					<div class="text-center py-24 bg-white dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-3xl">
						<div class="mx-auto w-16 h-16 text-slate-300 dark:text-slate-700 mb-6">
							<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3"></path></svg>
						</div>
						<h3 class="text-xl font-bold text-slate-900 dark:text-white uppercase tracking-tight">No active escrows</h3>
						<p class="text-slate-500 dark:text-slate-400 mt-2 max-w-sm mx-auto italic">Agreements will appear here once proposals are accepted.</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{(escrows || []).filter(e => e !== null).map(e => <EscrowCard escrow={e} isAdmin={isAdmin} userRole={effectiveRole} />)}
					</div>
				)
			) : (
				(proposals || []).length === 0 && !error ? (
					<div class="text-center py-24 bg-white dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-3xl">
						<h3 class="text-xl font-bold text-slate-900 dark:text-white uppercase tracking-tight">No pending proposals</h3>
						<p class="text-slate-500 dark:text-slate-400 mt-2 max-w-sm mx-auto italic">Start a new draft agreement to begin the escrow process.</p>
						<div class="flex justify-center gap-4 mt-6">
							<a href="/compose" class="bg-blue-600 text-white px-6 py-2.5 rounded-xl text-xs font-bold shadow-xl shadow-blue-500/20">Compose Draft</a>
							<button id="open-invite" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white px-6 py-2.5 rounded-xl text-xs font-bold shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">Invite Partner</button>
						</div>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{(proposals || []).filter(p => p !== null).map(p => (
							<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm p-6 flex flex-col justify-between">
								<div>
									<div class="flex justify-between items-start mb-4">
										<span class="text-[10px] font-black text-slate-400 uppercase tracking-widest bg-slate-50 dark:bg-slate-800 px-2 py-1 rounded">Proposal</span>
										<p class="text-xs font-bold text-blue-600">{p.amount} {p.currency}</p>
									</div>
									<h4 class="text-sm font-bold text-slate-800 dark:text-white mb-2">{p.description}</h4>
									<p class="text-[10px] text-slate-400 font-mono truncate mb-4 italic">ID: {p.id.substring(0, 16)}...</p>
									
									<div class="space-y-2 mb-6">
										<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Parties</p>
										<div class="flex justify-between text-[10px]">
											<span class="text-slate-500">Buyer:</span>
											<span class="font-bold dark:text-slate-300 text-slate-700">{p.buyer.split('::')[0]}</span>
										</div>
										<div class="flex justify-between text-[10px]">
											<span class="text-slate-500">Seller:</span>
											<span class="font-bold dark:text-slate-300 text-slate-700">{p.seller.split('::')[0]}</span>
										</div>
									</div>
								</div>

								{view === 'Seller' && (
									<div class="flex gap-2">
										<button 
											data-action="accept" 
											data-id={p.id}
											class="flex-1 bg-green-600 hover:bg-green-700 text-white py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 shadow-md shadow-green-500/20"
										>
											Accept & Sign
										</button>
										<button class="bg-slate-100 dark:bg-slate-800 text-slate-400 px-3 py-2 rounded-xl text-[10px] hover:text-red-500 transition-colors">×</button>
									</div>
								)}
								{view === 'Buyer' && (
									<div class="text-center py-2 text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-slate-50 dark:bg-slate-800 rounded-xl border border-slate-100 dark:border-slate-800">
										Awaiting Seller Signature
									</div>
								)}
							</div>
						))}
					</div>
				)
			)}
		</div>
	)}

	<InviteModal />
</Layout>

<script>
	import { 
		confirmConditions, 
		raiseDispute, 
		fundEscrow, 
		activateEscrow, 
		ratifySettlement, 
		finalizeSettlement 
	} from '../lib/api';
	import { getSession } from '../lib/auth';

	// Client-side Hydration & Role Check
	const session = getSession();
	if (session) {
		const isAdmin = session.scopes.includes('system:admin');
		if (isAdmin) {
			document.cookie = "admin-mode=true; path=/; max-age=3600";
		} else {
			document.cookie = "admin-mode=false; path=/; max-age=3600";
		}
	}

	const buttons = document.querySelectorAll('button[data-action]');
	buttons.forEach(btn => {
		btn.addEventListener('click', async (e) => {
			const target = e.currentTarget as HTMLButtonElement;
			const action = target.getAttribute('data-action');
			const id = target.getAttribute('data-id');
			if (!id) return;

			const urlParams = new URLSearchParams(window.location.search);
			const user = urlParams.get('view') || 'Buyer';

			const originalText = target.textContent;
			target.disabled = true;
			target.textContent = 'Processing...';

			try {
				if (action === 'fund') {
					const ref = prompt("Enter Custody Reference (e.g. TX-123):", "TX-" + Math.floor(Math.random()*1000));
					if (ref) await fundEscrow(id, ref);
					else throw new Error("Reference required");
				}
				else if (action === 'activate') await activateEscrow(id);
				else if (action === 'confirm') await confirmConditions(id);
				else if (action === 'dispute') await raiseDispute(id);
				else if (action === 'ratify') await ratifySettlement(id);
				else if (action === 'disburse') await finalizeSettlement(id);
				
				window.location.reload();
			} catch (err) {
				alert('Action failed: ' + err.message);
				target.disabled = false;
				target.textContent = originalText;
			}
		});
	});

	document.getElementById('open-invite')?.addEventListener('click', () => {
		window.dispatchEvent(new CustomEvent('open-invite-modal'));
	});
</script>
