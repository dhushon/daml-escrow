---
import Layout from '../layouts/Layout.astro';
import EscrowCard from '../components/EscrowCard.astro';
import { fetchEscrows } from '../lib/api';

const adminCookie = Astro.cookies.get('admin-mode');
const isAdmin = adminCookie?.value === 'true';

// Support view switching via query param
const view = Astro.url.searchParams.get('view') || 'Buyer';
const targetUser = isAdmin ? 'EscrowMediator' : view;

let escrows = [];
let error = null;

try {
	escrows = await fetchEscrows(targetUser);
} catch (e) {
	error = e.message;
}
---

<Layout title="My Escrows | Stablecoin Escrow">
	<div class="mb-8 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
		<div>
			<div class="flex items-center space-x-2 mb-1">
				<span class={`w-2 h-2 rounded-full ${isAdmin ? 'bg-blue-500' : 'bg-green-500'}`}></span>
				<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
					{isAdmin ? 'System-Wide Oversight' : `${view} Perspective`}
				</span>
			</div>
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Active Escrows</h2>
			<p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">
				{isAdmin ? 'Monitoring all active ledger obligations as Mediator.' : `Managing your pending payments as a ${view}.`}
			</p>
		</div>
		
		{!isAdmin && (
			<div class="inline-flex bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-1 shadow-sm transition-colors text-xs font-bold">
				<a 
					href="/?view=Buyer" 
					class={`px-4 py-1.5 rounded-lg transition-all ${view === 'Buyer' ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-slate-500 hover:text-slate-900 dark:hover:text-white'}`}
				>
					Buyer
				</a>
				<a 
					href="/?view=Seller" 
					class={`px-4 py-1.5 rounded-lg transition-all ${view === 'Seller' ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-slate-500 hover:text-slate-900 dark:hover:text-white'}`}
				>
					Seller
				</a>
			</div>
		)}
	</div>

	{error && (
		<div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 mb-8 rounded-r-xl transition-colors font-mono">
			<p class="text-sm font-bold text-red-700 dark:text-red-400">Connection Error: {error}</p>
		</div>
	)}

	{escrows.length === 0 && !error ? (
		<div class="text-center py-24 bg-white dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-3xl">
			<div class="mx-auto w-16 h-16 text-slate-300 dark:text-slate-700 mb-6">
				<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3"></path></svg>
			</div>
			<h3 class="text-xl font-bold text-slate-900 dark:text-white">No active escrows found</h3>
			<p class="text-slate-500 dark:text-slate-400 mt-2 max-w-sm mx-auto italic">Try switching views or initializing a transaction via the ledger.</p>
		</div>
	) : (
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{escrows.map(e => <EscrowCard escrow={e} isAdmin={isAdmin} />)}
		</div>
	)}
</Layout>

<script>
	import { releaseFunds, raiseDispute } from '../lib/api';

	const buttons = document.querySelectorAll('button[data-action]');
	buttons.forEach(btn => {
		btn.addEventListener('click', async (e) => {
			const target = e.currentTarget as HTMLButtonElement;
			const action = target.getAttribute('data-action');
			const id = target.getAttribute('data-id');
			
			if (!id) return;

			const originalText = target.textContent;
			target.disabled = true;
			target.textContent = 'Processing...';

			try {
				if (action === 'release') {
					await releaseFunds(id);
				} else if (action === 'dispute') {
					await raiseDispute(id);
				}
				window.location.reload();
			} catch (err) {
				alert('Action failed: ' + err.message);
				target.disabled = false;
				target.textContent = originalText;
			}
		});
	});
</script>
