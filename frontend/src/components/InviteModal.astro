---
// InviteModal.astro --- High-Assurance Participant Invitation
---

<div id="invite-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto">
	<div class="flex items-center justify-center min-h-screen px-4 text-center">
		<!-- Background Overlay - Reduced blur for better contrast -->
		<div class="fixed inset-0 transition-opacity bg-slate-900/80" id="modal-overlay"></div>

		<!-- Modal Card -->
		<div class="relative inline-block overflow-visible text-left align-middle transition-all transform bg-white dark:bg-slate-900 rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.3)] sm:my-8 sm:max-w-lg sm:w-full border border-slate-200 dark:border-slate-800 z-[110]">
			<div class="px-8 pt-8 pb-6 bg-brand-600 rounded-t-[22px]">
				<h3 class="text-xl font-black text-white uppercase tracking-tight">Invite Counterparty</h3>
				<p class="text-brand-100 text-xs mt-1 font-medium text-left">Extend a high-assurance invitation to a new institutional partner.</p>
			</div>

			<!-- High-Assurance: Absolute validation bypass for browser compliance -->
			<form id="invite-form" class="p-8 space-y-6" novalidate autocomplete="off">
				<div class="text-left relative">
					<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Institutional Identity (Email)</label>
					<div class="group relative">
						<!-- RENAMED name and id to definitively bypass browser regex helpers -->
						<input 
							type="text" 
							name="invitee_identity_raw" 
							id="invitee-identity-input"
							required
							placeholder="e.g. partner@vdatacloud.com"
							class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-brand-500 outline-none transition-all dark:text-white"
						/>
						<!-- Authoritative Tooltip -->
						<div class="absolute invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all bottom-full left-0 mb-2 w-full z-[120]">
							<div class="bg-slate-800 text-white text-[10px] p-2.5 rounded-lg shadow-2xl border border-slate-700 leading-relaxed">
								<span class="text-brand-400 font-bold">Supported Formats:</span><br/>
								• Standard: partner@company.com<br/>
								• Development: joey@depositor.devlocal
							</div>
							<!-- Tooltip Arrow -->
							<div class="w-2 h-2 bg-slate-800 border-r border-b border-slate-700 transform rotate-45 ml-4 -mt-1"></div>
						</div>
					</div>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Assigned Role</label>
						<select name="role" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm dark:text-white outline-none">
							<option value="Depositor">Depositor (Pledger)</option>
							<option value="Beneficiary">Beneficiary (Payee)</option>
						</select>
					</div>
					<div class="text-left">
						<label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Entity Type</label>
						<select name="inviteeType" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm dark:text-white outline-none">
							<option value="Business">Institutional/Business</option>
							<option value="Individual">Individual</option>
						</select>
					</div>
				</div>

				<div class="flex items-center justify-end space-x-4 pt-4">
					<button type="button" id="close-invite-btn" class="text-xs font-bold text-slate-400 hover:text-slate-600 transition-colors uppercase tracking-widest cursor-pointer bg-transparent border-none">Cancel</button>
					<button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-2.5 rounded-xl text-xs font-bold shadow-xl shadow-brand-500/20 transition-all border-none cursor-pointer">
						Send Invitation
					</button>
				</div>
			</form>
		</div>
	</div>
</div>

<script>
	import { createInvitation } from '../lib/api';

	const modal = document.getElementById('invite-modal');
	const overlay = document.getElementById('modal-overlay');
	const closeBtn = document.getElementById('close-invite-btn');
	const form = document.getElementById('invite-form') as HTMLFormElement;

	window.addEventListener('open-invite-modal', () => {
		modal?.classList.remove('hidden');
		document.getElementById('invitee-identity-input')?.focus();
	});

	const hideModal = () => modal?.classList.add('hidden');
	overlay?.addEventListener('click', hideModal);
	closeBtn?.addEventListener('click', hideModal);

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		
		// Use the new, browser-obfuscated key name
		const identity = formData.get('invitee_identity_raw') as string;
		const role = formData.get('role') as string;
		const type = formData.get('inviteeType') as string;

		if (!identity || identity.trim() === "") {
			alert('Institutional identity (Email) is required');
			return;
		}

		// Mock asset/terms for the initial invitation handshake
		const asset = { amount: 1.0, currency: 'USD', assetType: 'Stablecoin', assetId: 'PENDING' };
		const terms = { conditionDescription: 'Pending Onboarding', expiryDate: new Date(Date.now() + 86400000 * 7).toISOString() };

		try {
			console.log('Authoritatively sending invitation...', { identity, role, type });
			await createInvitation(identity, role, type, asset, terms);
			alert(`Invitation authoritatively sent to ${identity}`);
			hideModal();
		} catch (err: any) {
			console.error('CRITICAL: Invitation failed', err);
			alert('Failed to send invitation: ' + err.message);
		}
	});
</script>
