---
interface Props {
	escrowId: string;
}

const { escrowId } = Astro.props;
---

<div
	class="lifecycle-container bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm"
	data-escrow-id={escrowId}
>
	<div class="flex justify-between items-center mb-6 pb-4 border-b border-slate-100 dark:border-slate-800">
		<div>
			<div class="label-eyebrow text-slate-400 dark:text-slate-500 mb-1">Lifecycle</div>
			<h3 class="text-lg font-black text-slate-900 dark:text-white tracking-tight">Escrow Lifecycle Tracker</h3>
		</div>
		<span class="text-[10px] font-bold text-slate-500 dark:text-slate-400">
			Avg. Cycle: <span id="avg-time-val" class="font-mono text-slate-700 dark:text-slate-300">...</span>
		</span>
	</div>

	<div id="lifecycle-steps" class="flex flex-col">
		<div class="text-xs font-medium text-slate-400 dark:text-slate-500">Loading process map...</div>
	</div>

	<div class="mt-2 pt-4 border-t border-slate-100 dark:border-slate-800">
		<p class="text-[11px] font-medium text-slate-500 dark:text-slate-400">
			Current Hold: <span id="time-in-current" class="font-mono text-slate-700 dark:text-slate-300">...</span>
		</p>
	</div>
</div>

<script>
	import { fetchEscrowLifecycle } from '../lib/api';

	async function updateLifecycle(container: HTMLElement) {
		const id = container.getAttribute('data-escrow-id');
		if (!id) return;

		try {
			const data = await fetchEscrowLifecycle(id);
			const stepsList = container.querySelector('#lifecycle-steps');
			if (!stepsList) return;

			stepsList.innerHTML = data.steps.map((step: any, idx: number) => {
				const status = step.status.toLowerCase();
				const isCompleted = status === 'completed';
				const isCurrent = status === 'current';
				const isLast = idx === data.steps.length - 1;

				const dotClasses = isCompleted
					? 'bg-status-active border-status-active'
					: isCurrent
					? 'bg-status-funded border-status-funded shadow-[0_0_10px_rgba(59,130,246,0.5)] animate-pulse-slow'
					: 'bg-white dark:bg-slate-900 border-slate-300 dark:border-slate-700';

				const titleClasses = isCompleted
					? 'text-slate-900 dark:text-white'
					: isCurrent
					? 'text-brand-600 dark:text-brand-400'
					: 'text-slate-400 dark:text-slate-500';

				const lineClasses = isCompleted
					? 'bg-status-active'
					: 'bg-slate-200 dark:bg-slate-700';

				return `
					<div class="flex gap-4 relative">
						<div class="flex flex-col items-center w-4">
							<div class="w-3 h-3 rounded-full border-2 z-10 ${dotClasses}"></div>
							${isLast ? '' : `<div class="w-0.5 flex-grow my-1 ${lineClasses}"></div>`}
						</div>
						<div class="pb-6">
							<div class="text-[13px] font-bold ${titleClasses}">${step.state}</div>
							<div class="text-xs font-medium text-slate-500 dark:text-slate-400">${step.description}</div>
							${step.timestamp ? `<div class="text-[10px] font-mono text-status-active mt-1">${new Date(step.timestamp).toLocaleString()}</div>` : ''}
						</div>
					</div>
				`;
			}).join('');

			const avgTime = container.querySelector('#avg-time-val');
			const timeInCurrent = container.querySelector('#time-in-current');
			if (avgTime) avgTime.textContent = data.avgTimeToComplete;
			if (timeInCurrent) timeInCurrent.textContent = data.timeInCurrent;

		} catch (e) {
			console.error("Failed to load lifecycle", e);
		}
	}

	// Initialize
	const containers = document.querySelectorAll('.lifecycle-container');
	containers.forEach(c => updateLifecycle(c as HTMLElement));
</script>
