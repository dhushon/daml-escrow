---
import type { EscrowResponse } from '../lib/api';

interface Props {
	escrow: EscrowResponse;
	isAdmin?: boolean;
	userRole?: string; // 'Depositor', 'Beneficiary', 'Mediator', 'Issuer'
}

const { escrow, isAdmin = false, userRole = 'Depositor' } = Astro.props;

const statusColors: Record<string, string> = {
	DRAFT: 'bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-400 border border-slate-200 dark:border-slate-700',
	FUNDED: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 border border-blue-200 dark:border-blue-800',
	ACTIVE: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800',
	DISPUTED: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800',
	PROPOSED: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 border border-amber-200 dark:border-amber-800',
	SETTLED: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400 border border-purple-200 dark:border-purple-800',
};

// Normalize data from different templates
const amount = escrow.amount || 0;
const currency = escrow.currency || 'USD';
const state = escrow.state || 'DRAFT';
const currentMilestoneIndex = escrow.currentMilestoneIndex || 0;

let milestones = escrow.milestones || [];
if (milestones.length === 0 && escrow.terms && escrow.terms.conditionDescription) {
	const desc = escrow.terms.conditionDescription;
	const parts = desc.split(',');
	milestones = parts.map((part, idx) => {
		const colonIdx = part.lastIndexOf(':');
		let label = part.trim();
		let mAmount = amount; // fallback to total amount
		if (colonIdx !== -1) {
			label = part.substring(0, colonIdx).trim();
			const amountStr = part.substring(colonIdx + 1).trim();
			mAmount = parseFloat(amountStr) || amount;
		}
		return {
			label: label,
			amount: mAmount,
			completed: idx < currentMilestoneIndex
		};
	});
}

const steps = [
	{ label: 'Draft' },
	{ label: 'Funded' },
	{ label: 'Active' },
	{ label: 'Settled' }
];

let currentStepIndex = 0;
switch (state) {
	case 'DRAFT':
		currentStepIndex = 0;
		break;
	case 'FUNDED':
		currentStepIndex = 1;
		break;
	case 'ACTIVE':
	case 'DISPUTED':
		currentStepIndex = 2;
		break;
	case 'PROPOSED':
	case 'SETTLED':
	case 'DISBURSING':
		currentStepIndex = 3;
		break;
	default:
		currentStepIndex = 0;
}
---

<div class="glass-card interactive-card rounded-3xl overflow-hidden group flex flex-col justify-between h-full">
	<div class="p-6">
		<!-- Card Top Info -->
		<div class="flex justify-between items-start mb-4">
			<div>
				<h4 class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1.5 flex items-center gap-1">
					Escrow ID
					<span class="relative inline-block group/tooltip cursor-help">
						<svg class="w-3.5 h-3.5 text-slate-300 dark:text-slate-600 hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						<span class="absolute z-[200] pointer-events-none opacity-0 group-hover/tooltip:opacity-100 transition-opacity bg-slate-950/95 dark:bg-slate-900 border border-slate-800 text-white text-[10px] p-2.5 rounded-xl shadow-xl w-48 -left-20 -mt-24 leading-relaxed normal-case font-normal">The unique ledger contract identifier for this Escrow instance.</span>
					</span>
				</h4>
				<code class="text-[10px] text-brand-500 font-mono bg-brand-500/5 dark:bg-brand-500/10 px-2.5 py-1.5 rounded-xl border border-brand-500/10 select-all transition-colors font-bold">{escrow.id.substring(0, 16)}...</code>
			</div>
			
			<div class="relative group/state">
				<span class={`px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all ${statusColors[state] || 'bg-slate-100 border-slate-200'}`}>
					{state}
				</span>
				<span class="absolute z-[200] pointer-events-none opacity-0 group-hover/state:opacity-100 transition-opacity bg-slate-950/95 dark:bg-slate-900 border border-slate-800 text-white text-[10px] p-2.5 rounded-xl shadow-xl w-48 -left-20 mt-3 normal-case font-normal leading-relaxed text-center">
					{state === 'DRAFT' && "Agreement terms are being negotiated between parties."}
					{state === 'FUNDED' && "Depositor has locked the required stablecoins on-chain."}
					{state === 'ACTIVE' && "Escrow activated. Milestones are ready for verification."}
					{state === 'PROPOSED' && "Settlement proposal offered. Requires bilateral signature."}
					{state === 'DISPUTED' && "Dispute raised. A mediator is investigating details."}
					{state === 'SETTLED' && "Settlement reached and approved. Awaiting final disbursement."}
				</span>
			</div>
		</div>

		<!-- Amount Details -->
		<div class="grid grid-cols-2 gap-4 my-5 py-3 border-y border-slate-100/50 dark:border-slate-800/40">
			<div>
				<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Contract Amount</p>
				<p class="text-xl font-black text-slate-900 dark:text-white leading-none tracking-tight">{amount.toLocaleString()} <span class="text-xs font-black text-brand-500">{currency}</span></p>
			</div>
			<div class="text-right">
				<p class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-1">Active Milestones</p>
				<p class="text-sm font-black text-slate-700 dark:text-slate-300">
					{milestones.length > 0 ? (currentMilestoneIndex + 1) : 0} 
					<span class="text-slate-300 dark:text-slate-700">/</span> {milestones.length}
				</p>
			</div>
		</div>

		<!-- Multi-Party Stakeholders & Thresholds -->
		{escrow.depositors && escrow.depositors.length > 0 && (
			<div class="mb-4 text-xs">
				<div class="flex justify-between items-center mb-1.5">
					<span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Depositors ({escrow.depositorAcceptances?.length || 0}/{escrow.depositorThreshold || 1} signed)</span>
				</div>
				<div class="flex flex-wrap gap-1.5">
					{escrow.depositors.map(d => {
						const name = d.split('@')[0] || d;
						const isSigned = escrow.depositorAcceptances?.includes(d);
						return (
							<span class={`px-2 py-1 rounded-lg text-[10px] font-bold border transition-colors ${isSigned ? 'bg-emerald-500/10 text-emerald-600 border-emerald-500/20' : 'bg-slate-50 dark:bg-slate-800 text-slate-400 border-slate-200 dark:border-slate-700'}`}>
								{name}
							</span>
						);
					})}
				</div>
			</div>
		)}

		{escrow.beneficiaries && escrow.beneficiaries.length > 0 && (
			<div class="mb-4 text-xs">
				<div class="flex justify-between items-center mb-1.5">
					<span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Beneficiaries ({escrow.beneficiaryAcceptances?.length || 0}/{escrow.beneficiaryThreshold || 1} signed)</span>
				</div>
				<div class="flex flex-wrap gap-1.5">
					{escrow.beneficiaries.map(b => {
						const name = b.split('@')[0] || b;
						const isSigned = escrow.beneficiaryAcceptances?.includes(b);
						return (
							<span class={`px-2 py-1 rounded-lg text-[10px] font-bold border transition-colors ${isSigned ? 'bg-emerald-500/10 text-emerald-600 border-emerald-500/20' : 'bg-slate-50 dark:bg-slate-800 text-slate-400 border-slate-200 dark:border-slate-700'}`}>
								{name}
							</span>
						);
					})}
				</div>
			</div>
		)}

		<!-- Visual Stepper Timeline -->
		<div class="my-6 px-1">
			<div class="flex items-center justify-between relative">
				<!-- Background Connector Bar -->
				<div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-0.5 bg-slate-200 dark:bg-slate-800 -z-10 rounded-full">
					<div 
						class="h-full bg-brand-500 rounded-full transition-all duration-700" 
						style={`width: ${(currentStepIndex / (steps.length - 1)) * 100}%`}
					></div>
				</div>
				
				{steps.map((s, idx) => {
					const isCompleted = idx < currentStepIndex;
					const isActive = idx === currentStepIndex;
					
					let circleClass = "bg-slate-100 dark:bg-slate-900 border-slate-300 dark:border-slate-800 text-slate-400";
					let textClass = "text-slate-400 dark:text-slate-600";
					
					if (isCompleted) {
						circleClass = "bg-brand-500 border-brand-500 text-white shadow-[0_0_10px_rgba(59,130,246,0.3)]";
						textClass = "text-brand-500 font-bold";
					} else if (isActive) {
						if (state === 'DISPUTED') {
							circleClass = "bg-rose-500 border-rose-500 text-white animate-pulse shadow-[0_0_12px_rgba(244,63,94,0.4)]";
							textClass = "text-rose-500 font-black";
						} else if (state === 'PROPOSED') {
							circleClass = "bg-amber-500 border-amber-500 text-white animate-pulse shadow-[0_0_12px_rgba(245,158,11,0.4)]";
							textClass = "text-amber-500 font-black";
						} else {
							circleClass = "bg-brand-500 border-brand-500 text-white shadow-[0_0_12px_rgba(59,130,246,0.4)]";
							textClass = "text-brand-500 font-black";
						}
					}
					
					return (
						<div class="flex flex-col items-center relative z-10">
							<div class={`w-5 h-5 rounded-full border-2 flex items-center justify-center text-[9px] font-black transition-all duration-500 ${circleClass}`}>
								{isCompleted ? (
									<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
									</svg>
								) : (idx + 1)}
							</div>
							<span class={`text-[8px] font-black uppercase tracking-wider mt-2.5 ${textClass}`}>
								{s.label}
							</span>
						</div>
					);
				})}
			</div>
		</div>

		<!-- Milestones List -->
		<div class="space-y-2 mt-4 max-h-48 overflow-y-auto pr-1">
			{milestones.map((m, i) => (
				<div class="flex items-center space-x-3 text-xs bg-slate-50/50 dark:bg-slate-800/10 p-2.5 rounded-xl border border-slate-100/50 dark:border-slate-800/20">
					<div class={`w-2.5 h-2.5 rounded-full transition-all duration-500 flex-shrink-0 ${m.completed ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]' : (i === currentMilestoneIndex && state === 'ACTIVE' ? 'bg-brand-500 animate-pulse shadow-[0_0_8px_rgba(59,130,246,0.4)]' : 'bg-slate-200 dark:bg-slate-800')}`}></div>
					<span class={`font-bold tracking-tight truncate ${m.completed ? 'text-slate-400 dark:text-slate-600 line-through' : 'text-slate-700 dark:text-slate-300'}`}>{m.label}</span>
					<span class="ml-auto font-mono text-[10px] text-brand-500 font-black">{m.amount.toLocaleString()} <span class="text-[9px] text-slate-400">{currency}</span></span>
				</div>
			))}
			{milestones.length === 0 && <p class="text-[10px] italic text-slate-400 text-center py-2">No contract milestones defined</p>}
		</div>
	</div>

	<!-- Action Footer -->
	<div class="bg-slate-50/80 dark:bg-slate-950/20 px-6 py-4 border-t border-slate-100/50 dark:border-slate-800/50 flex justify-between gap-3 transition-colors mt-auto">
		<div class="flex w-full gap-2.5">
			{state === 'DRAFT' && userRole === 'Depositor' && (
				<button 
					data-action="fund" 
					data-id={escrow.id}
					class="flex-1 bg-brand-600 text-white px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-brand-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-brand-500/20 cursor-pointer border-none"
				>
					Fund Contract
				</button>
			)}

			{state === 'FUNDED' && userRole === 'Issuer' && (
				<button 
					data-action="activate" 
					data-id={escrow.id}
					class="flex-1 bg-emerald-600 text-white px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-emerald-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-emerald-500/20 cursor-pointer border-none"
				>
					Activate Contract
				</button>
			)}

			{state === 'ACTIVE' && (
				<>
					{userRole === 'Mediator' && (
						<button 
							data-action="confirm" 
							data-id={escrow.id}
							class="flex-1 bg-emerald-600 text-white px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-emerald-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-emerald-500/20 cursor-pointer border-none"
						>
							Approve Release
						</button>
					)}
					{(userRole === 'Depositor' || userRole === 'Beneficiary') && (
						<button 
							data-action="dispute" 
							data-id={escrow.id}
							class="flex-1 bg-rose-50/80 dark:bg-rose-950/10 border border-rose-200 dark:border-rose-900/30 text-rose-600 px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-rose-600 hover:text-white hover:scale-[1.02] active:scale-95 transition-all cursor-pointer"
						>
							Raise Dispute
						</button>
					)}
				</>
			)}

			{state === 'PROPOSED' && (userRole === 'Depositor' || userRole === 'Beneficiary') && (
				<button 
					data-action="ratify" 
					data-id={escrow.id}
					class="flex-1 bg-amber-600 text-white px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-amber-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-amber-500/20 cursor-pointer border-none"
				>
					Ratify Settlement
				</button>
			)}

			{state === 'SETTLED' && userRole === 'Issuer' && (
				<button 
					data-action="disburse" 
					data-id={escrow.id}
					class="flex-1 bg-purple-600 text-white px-4 py-3 rounded-2xl text-xs font-black uppercase tracking-wider hover:bg-purple-700 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-purple-500/20 cursor-pointer border-none"
				>
					Disburse stablecoins
				</button>
			)}

			{state === 'SETTLED' && userRole !== 'Issuer' && (
				<div class="w-full text-center py-3.5 text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest bg-slate-100 dark:bg-slate-800/40 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
					Awaiting stablecoin Disbursement
				</div>
			)}
			
			{!isAdmin && userRole === 'Guest' && (
				<div class="w-full text-center py-3.5 text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest bg-slate-50 dark:bg-slate-800/20 rounded-2xl border border-slate-200/50 dark:border-slate-800/30">
					View-Only Perspective
				</div>
			)}
		</div>
	</div>
</div>
