---
import type { EscrowResponse } from '../lib/api';

interface Props {
	escrow: EscrowResponse;
}

const { escrow } = Astro.props;

const statusColors = {
	Active: 'bg-green-100 text-green-800',
	Disputed: 'bg-red-100 text-red-800',
};
---

<div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden">
	<div class="p-5">
		<div class="flex justify-between items-start mb-4">
			<div>
				<h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Escrow ID</h3>
				<code class="text-xs text-indigo-600 font-mono break-all bg-indigo-50 px-2 py-1 rounded">{escrow.id}</code>
			</div>
			<span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[escrow.state]}`}>
				{escrow.state}
			</span>
		</div>

		<div class="grid grid-cols-2 gap-4 mb-6">
			<div>
				<p class="text-xs text-gray-500 uppercase">Amount</p>
				<p class="text-lg font-bold">{escrow.amount} <span class="text-sm font-normal text-gray-500">{escrow.currency}</span></p>
			</div>
			<div class="text-right">
				<p class="text-xs text-gray-500 uppercase">Milestone</p>
				<p class="text-sm font-semibold">{escrow.currentMilestoneIndex + 1} of {escrow.milestones.length}</p>
			</div>
		</div>

		<div class="space-y-3">
			{escrow.milestones.map((m, i) => (
				<div class="flex items-center space-x-3 text-sm">
					<div class={`w-2 h-2 rounded-full ${m.completed ? 'bg-green-500' : (i === escrow.currentMilestoneIndex ? 'bg-indigo-500 animate-pulse' : 'bg-gray-300')}`}></div>
					<span class={m.completed ? 'text-gray-400 line-through' : 'text-gray-700'}>{m.label}</span>
					<span class="ml-auto text-xs text-gray-500">{m.amount} {escrow.currency}</span>
				</div>
			))}
		</div>
	</div>

	<div class="bg-gray-50 px-5 py-3 border-t border-gray-100 flex justify-between gap-3">
		<button 
			data-action="release" 
			data-id={escrow.id}
			class="flex-1 bg-white border border-gray-300 text-gray-700 px-3 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
			disabled={escrow.state === 'Disputed'}
		>
			Approve
		</button>
		<button 
			data-action="dispute" 
			data-id={escrow.id}
			class="flex-1 bg-white border border-red-200 text-red-600 px-3 py-2 rounded-lg text-sm font-semibold hover:bg-red-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
			disabled={escrow.state === 'Disputed'}
		>
			Dispute
		</button>
	</div>
</div>
