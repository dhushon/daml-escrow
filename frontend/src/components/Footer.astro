---
---

<footer class="bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 p-4 shadow-inner transition-colors duration-300">
    <div class="container mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
        
        <!-- Left: Identity & Copyright -->
        <div class="flex flex-col md:flex-row items-center gap-4 text-xs font-medium text-slate-500 dark:text-slate-400">
            <div id="footer-identity" class="flex items-center gap-2 px-3 py-1 bg-slate-100 dark:bg-slate-800 rounded-full border border-slate-200 dark:border-slate-700">
                <span class="w-2 h-2 rounded-full bg-slate-300 animate-pulse"></span>
                <span>Identifying...</span>
            </div>
            <p>copyright (c) 2006, Data Cloud, LLC, All Rights Reserved</p>
        </div>

        <!-- Center: Health Indicator -->
        <div class="relative group">
            <button id="health-check-btn" class="flex items-center gap-2 px-4 py-1.5 rounded-xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-blue-400 dark:hover:border-blue-500 transition-all cursor-pointer">
                <div id="health-indicator" class="w-3 h-3 rounded-full bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.5)]"></div>
                <span id="health-label" class="text-[10px] font-black uppercase tracking-widest text-slate-600 dark:text-slate-300">Checking Systems...</span>
                <span id="health-last-sync" class="text-[9px] font-mono text-slate-400">--:--:--</span>
            </button>

            <!-- Health Summary Tooltip -->
            <div id="health-tooltip" class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-64 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl p-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 border-b border-slate-100 dark:border-slate-800 pb-2">System Health Summary</h4>
                <div class="space-y-3" id="health-services-list">
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-300">Escrow API</span>
                        <span class="text-[10px] text-green-500 font-bold">ONLINE</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-300">Canton Ledger</span>
                        <span class="text-[10px] text-green-500 font-bold">CONNECTED</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-300">Oracle Node</span>
                        <span class="text-[10px] text-amber-500 font-bold">LATENT</span>
                    </div>
                </div>
                <div class="mt-4 pt-2 border-t border-slate-100 dark:border-slate-800">
                    <div class="flex items-center justify-between">
                        <span class="text-[9px] text-slate-400 italic">Auto-refresh:</span>
                        <select id="health-poll-interval" class="text-[9px] bg-slate-50 dark:bg-slate-800 border-none rounded px-1 outline-none text-blue-600 font-bold cursor-pointer">
                            <option value="5000">5s</option>
                            <option value="15000" selected>15s</option>
                            <option value="30000">30s</option>
                            <option value="60000">1m</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Toolbar -->
        <div class="flex items-center gap-4">
            <div class="h-4 w-px bg-slate-200 dark:bg-slate-800 hidden md:block"></div>
            <button id="refresh-dashboard" class="relative group/refresh p-2 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 text-slate-400 hover:text-blue-600 transition-all cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 110 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
                </svg>
                <span class="absolute bottom-full right-0 mb-2 opacity-0 group-hover/refresh:opacity-100 transition-opacity bg-slate-800 text-white text-[10px] py-1 px-2 rounded pointer-events-none whitespace-nowrap">
                    refresh
                </span>
            </button>
        </div>
    </div>
</footer>

<script>
    import { fetchHealth } from '../lib/api';
    import { getSession } from '../lib/auth';

    let pollTimer: any = null;

    function updateIdentity() {
        const session = getSession();
        const footerIdentity = document.getElementById('footer-identity');
        if (!footerIdentity) return;

        if (session) {
            const role = session.isBypass ? session.identity.displayName : 'Authenticated';
            footerIdentity.innerHTML = `
                <span class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_5px_rgba(34,197,94,0.5)]"></span>
                <span class="font-bold text-slate-700 dark:text-slate-200">${session.email}</span>
                <span class="text-[10px] text-slate-400 px-1.5 py-0.5 bg-slate-200 dark:bg-slate-700 rounded-md font-black uppercase tracking-tighter">${role}</span>
            `;
        } else {
            footerIdentity.innerHTML = `
                <span class="w-2 h-2 rounded-full bg-slate-300"></span>
                <span>Guest User</span>
            `;
        }
    }

    async function checkHealth() {
        const indicator = document.getElementById('health-indicator');
        const label = document.getElementById('health-label');
        const lastSync = document.getElementById('health-last-sync');
        const servicesList = document.getElementById('health-services-list');

        if (!indicator || !label || !lastSync) return;

        label.textContent = 'Synchronizing...';
        indicator.className = 'w-3 h-3 rounded-full bg-blue-500 animate-spin border-2 border-white border-t-transparent';

        try {
            const health = await fetchHealth();
            const now = new Date();
            lastSync.textContent = now.toLocaleTimeString([], { hour12: false });

            // In this demo, we use the backend response to drive the indicator
            if (health.status === 'UP') {
                indicator.className = 'w-3 h-3 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]';
                label.textContent = 'All Systems Operational';
            } else {
                indicator.className = 'w-3 h-3 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]';
                label.textContent = 'System Degraded';
            }

            // Update tooltip summary with REAL service data
            if (servicesList && health.services) {
                let servicesHtml = '';
                for (const [name, svc] of Object.entries(health.services)) {
                    const statusColor = svc.status === 'UP' ? 'text-green-500' : (svc.status === 'DEGRADED' ? 'text-amber-500' : 'text-red-500');
                    const displayName = name.charAt(0).toUpperCase() + name.slice(1);
                    
                    servicesHtml += `
                        <div class="flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-xs font-bold text-slate-700 dark:text-slate-300">${displayName}</span>
                                ${svc.message ? `<span class="text-[8px] text-slate-400 leading-none">${svc.message}</span>` : ''}
                            </div>
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] ${statusColor} font-bold">${svc.status}</span>
                                ${svc.latencyMs ? `<span class="text-[8px] text-slate-500 font-mono">${svc.latencyMs}ms</span>` : ''}
                            </div>
                        </div>
                    `;
                }
                
                // Add API Info
                servicesHtml += `
                    <div class="mt-2 pt-2 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between">
                        <span class="text-[9px] text-slate-400 uppercase font-black">Escrow API v${health.version}</span>
                        <span class="text-[9px] text-slate-400 font-mono">${Math.round(health.memoryUsage)}MB RAM</span>
                    </div>
                `;
                
                servicesList.innerHTML = servicesHtml;
            }

        } catch (err) {
            indicator.className = 'w-3 h-3 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]';
            label.textContent = 'Connection Offline';
            lastSync.textContent = 'FAILED';
            
            if (servicesList) {
                servicesList.innerHTML = `
                    <div class="py-2 text-center text-[10px] text-red-400 italic">
                        The Escrow API is unreachable. Check your connection or ensure the backend is running.
                    </div>
                `;
            }
        }
    }

    function startPolling() {
        if (pollTimer) clearInterval(pollTimer);
        const interval = parseInt(localStorage.getItem('health_poll_interval') || '15000');
        pollTimer = setInterval(checkHealth, interval);
    }

    // Initialize
    updateIdentity();
    checkHealth();
    startPolling();

    // Event Listeners
    document.getElementById('health-check-btn')?.addEventListener('click', checkHealth);
    document.getElementById('refresh-dashboard')?.addEventListener('click', () => window.location.reload());

    const pollSelect = document.getElementById('health-poll-interval') as HTMLSelectElement;
    if (pollSelect) {
        pollSelect.value = localStorage.getItem('health_poll_interval') || '15000';
        pollSelect.addEventListener('change', (e) => {
            const val = (e.target as HTMLSelectElement).value;
            localStorage.setItem('health_poll_interval', val);
            startPolling();
        });
    }

    // Listen for auth changes
    window.addEventListener('storage', (e) => {
        if (e.key === 'auth_session') updateIdentity();
    });
</script>
