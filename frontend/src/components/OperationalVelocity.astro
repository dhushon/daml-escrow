---
interface Props {
	latencies: Record<string, number>;
	successRate: number;
}

const { latencies, successRate } = Astro.props;

// Calculate funnel widths based on a hypothetical drop-off (simulation)
const funnelSteps = [
	{ label: 'Proposals', value: 100, color: '#3b82f6' },
	{ label: 'Funded', value: 92, color: '#6366f1' },
	{ label: 'Active', value: 88, color: '#8b5cf6' },
	{ label: 'Settled', value: successRate, color: '#10b981' }
];

const maxLatency = Math.max(...Object.values(latencies));
---

<div class="velocity-card bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
	<div class="flex justify-between items-center mb-10">
		<div>
			<h3 class="text-xl font-black text-slate-900 dark:text-white tracking-tight">Operational Velocity</h3>
			<p class="text-xs font-medium text-slate-500 mt-1 uppercase tracking-widest">Noves-Verified Lifecycle Analytics</p>
		</div>
		<div class="text-right">
			<span class="text-3xl font-black text-green-500">{successRate}%</span>
			<p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Settlement Rate</p>
		</div>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
		<!-- Stage Latency Heatmap -->
		<div>
			<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-6">Stage Duration (Minutes)</p>
			<div class="space-y-4">
				{Object.entries(latencies).map(([stage, mins]) => (
					<div class="relative">
						<div class="flex justify-between items-center mb-1">
							<span class="text-xs font-bold text-slate-700 dark:text-slate-300">{stage}</span>
							<span class="text-xs font-mono text-slate-500">{mins}m</span>
						</div>
						<div class="w-full bg-slate-100 dark:bg-slate-800 h-3 rounded-full overflow-hidden">
							<div 
								class="h-full rounded-full transition-all duration-1000 bg-gradient-to-r from-blue-500 to-indigo-500 shadow-[0_0_10px_rgba(59,130,246,0.3)]" 
								style={`width: ${(mins / maxLatency) * 100}%`}
							></div>
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- Settlement Funnel -->
		<div class="flex flex-col items-center justify-center">
			<p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-8 self-start w-full text-center">Conversion Funnel</p>
			<div class="w-full max-w-[280px] space-y-1">
				{funnelSteps.map((step, i) => (
					<div 
						class="funnel-step flex items-center justify-center text-[10px] font-black text-white uppercase tracking-tighter transition-all hover:scale-[1.02]"
						style={`
							width: ${step.value}%;
							height: ${40 - i * 4}px;
							background: ${step.color};
							margin: 0 auto;
							clip-path: polygon(0% 0%, 100% 0%, 90% 100%, 10% 100%);
							opacity: ${0.7 + (i * 0.1)};
						`}
					>
						{step.label}
					</div>
				))}
			</div>
		</div>
	</div>
</div>

<style>
	.velocity-card {
		transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
	}
	.velocity-card:hover {
		transform: translateY(-4px);
	}
	.funnel-step {
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
	}
</style>
