{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stablecoin-escrow.io/schemas/grants.v1.json",
  "title": "Grants & Federal Funding Metadata",
  "type": "object",
  "properties": {
    "opportunityId": { "type": "string" },
    "assistanceListing": { "type": "string", "pattern": "^[0-9]{2}\\.[0-9]{3}$" },
    "uei": { "type": "string", "minLength": 12, "maxLength": 12 },
    "grantAwardNumber": { "type": "string" },
    "cfda": { "type": "string" },
    "programName": { "type": "string" },
    "reportingDeadline": { "type": "string", "format": "date-time" }
  },
  "required": ["opportunityId", "uei"]
}
